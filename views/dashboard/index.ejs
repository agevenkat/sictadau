<% activePage = 'dashboard'; %>

<!-- Stat cards -->
<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="card stat-card h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="icon-box" style="background:#dbeafe;color:#1d4ed8"><i class="bi bi-people-fill"></i></div>
        <div>
          <div class="stat-value"><%= members.active || 0 %></div>
          <div class="stat-label">Active Members</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card stat-card h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="icon-box" style="background:#fef3c7;color:#d97706"><i class="bi bi-receipt"></i></div>
        <div>
          <div class="stat-value"><%= vouchers.pending || 0 %></div>
          <div class="stat-label">Pending Vouchers</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card stat-card h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="icon-box" style="background:#dcfce7;color:#16a34a"><i class="bi bi-currency-rupee"></i></div>
        <div>
          <div class="stat-value">₹<%= Math.round(vouchers.paid_amount || 0).toLocaleString('en-IN') %></div>
          <div class="stat-label">Disbursed</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card stat-card h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="icon-box" style="background:<%= balance >= 0 ? '#dcfce7' : '#fee2e2' %>;color:<%= balance >= 0 ? '#16a34a' : '#dc2626' %>">
          <i class="bi bi-bank"></i>
        </div>
        <div>
          <div class="stat-value">₹<%= Math.round(Math.abs(balance)).toLocaleString('en-IN') %></div>
          <div class="stat-label">Balance (<%= balance >= 0 ? 'Credit' : 'Deficit' %>)</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Overview cards -->
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card stat-card h-100">
      <div class="card-body">
        <h6 class="text-muted mb-3" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;">Members</h6>
        <% [['Total', members.total, ''], ['Active', members.active, 'text-success'], ['Expired', members.expired, 'text-warning'], ['Cancelled', members.cancelled, 'text-danger']].forEach(([label, val, cls]) => { %>
        <div class="d-flex justify-content-between mb-2">
          <span class="small <%= cls %>"><%= label %></span>
          <strong class="<%= cls %>"><%= val || 0 %></strong>
        </div>
        <% }) %>
        <a href="/members" class="btn btn-sm btn-outline-primary w-100 mt-2">View Members</a>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card stat-card h-100">
      <div class="card-body">
        <h6 class="text-muted mb-3" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;">Projects</h6>
        <% [['Total', projects.total, ''], ['Pending', projects.pending, 'text-warning'], ['Paid', projects.paid, 'text-success'], ['Total Billed', '₹' + Math.round(projects.total_amount||0).toLocaleString('en-IN'), '']].forEach(([label, val, cls]) => { %>
        <div class="d-flex justify-content-between mb-2">
          <span class="small <%= cls %>"><%= label %></span>
          <strong class="<%= cls %>"><%= val || 0 %></strong>
        </div>
        <% }) %>
        <a href="/projects" class="btn btn-sm btn-outline-primary w-100 mt-2">View Projects</a>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card stat-card h-100">
      <div class="card-body">
        <h6 class="text-muted mb-3" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.05em;">Vouchers</h6>
        <% [['Total', vouchers.total, ''], ['Pending', vouchers.pending, 'text-warning'], ['Paid', vouchers.paid, 'text-success'], ['Pending Amt', '₹' + Math.round(vouchers.pending_amount||0).toLocaleString('en-IN'), 'text-warning']].forEach(([label, val, cls]) => { %>
        <div class="d-flex justify-content-between mb-2">
          <span class="small <%= cls %>"><%= label %></span>
          <strong class="<%= cls %>"><%= val || 0 %></strong>
        </div>
        <% }) %>
        <a href="/vouchers" class="btn btn-sm btn-outline-primary w-100 mt-2">View Vouchers</a>
      </div>
    </div>
  </div>
</div>

<!-- Tables -->
<div class="row g-3">
  <div class="col-md-6">
    <div class="table-card card">
      <div class="card-header d-flex justify-content-between align-items-center py-2">
        <span class="fw-semibold"><i class="bi bi-clock text-warning me-2"></i>Pending Payments</span>
        <a href="/vouchers?status=Pending" class="btn btn-sm btn-outline-primary">View All</a>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead><tr><th>#</th><th>Artist</th><th>Project</th><th>Amount</th><th></th></tr></thead>
          <tbody>
            <% if (pendingVouchers.length === 0) { %>
              <tr><td colspan="5" class="text-center text-muted py-3 small">No pending payments</td></tr>
            <% } else { %>
              <% pendingVouchers.forEach(v => { %>
              <tr>
                <td class="text-muted small"><%= v.id %></td>
                <td class="small"><%= v.full_name %></td>
                <td class="small text-muted"><%= v.film_name %></td>
                <td class="small fw-medium">₹<%= (v.final_amount||0).toLocaleString('en-IN') %></td>
                <td>
                  <form action="/vouchers/<%= v.id %>/pay" method="POST" class="d-inline">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="hidden" name="payment_method" value="NEFT">
                    <button class="btn btn-success" style="font-size:0.7rem;padding:2px 8px;">Pay</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="table-card card">
      <div class="card-header d-flex justify-content-between align-items-center py-2">
        <span class="fw-semibold"><i class="bi bi-file-earmark-text text-primary me-2"></i>Recent Projects</span>
        <a href="/projects" class="btn btn-sm btn-outline-primary">View All</a>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead><tr><th>Film</th><th>Company</th><th>Amount</th><th>Status</th></tr></thead>
          <tbody>
            <% recentProjects.forEach(p => { %>
            <tr>
              <td><a href="/projects/<%= p.id %>" class="text-decoration-none small fw-medium"><%= p.film_name %></a></td>
              <td class="small text-muted"><%= p.production_company %></td>
              <td class="small">₹<%= (p.amount||0).toLocaleString('en-IN') %></td>
              <td><span class="badge badge-<%= p.status.toLowerCase() %>"><%= p.status %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
