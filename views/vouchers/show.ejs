<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Voucher #<%= voucher.id %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', sans-serif;
      font-size: 13px;
      color: #000000;
      margin: 0;
      padding: 20px;
    }
    .voucher-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 20px;
      background: white;
      border-radius: 4px;
    }
    .header-meta {
      border: 1px solid #ccc;
      padding: 8px 12px;
      margin-bottom: 15px;
      font-size: 12px;
      display: flex;
      justify-content: space-between;
    }
    .from-to-table {
      width: 100%;
      border: 1px solid #ccc;
      margin-bottom: 15px;
    }
    .from-to-table td {
      padding: 12px;
      vertical-align: top;
      color: #000000;
    }
    .from-to-table td:first-child {
      border-right: 1px solid #ccc;
      width: 50%;
    }
    .union-logo {
      width: 75px;
      height: 75px;
      object-fit: contain;
      float: left;
      margin-right: 10px;
    }
    table.data-table {
      width: 100%;
      border-collapse: collapse;
    }
    table.data-table th, table.data-table td {
      border: 1px solid #999;
      padding: 6px 10px;
      color: #000000;
    }
    table.data-table th {
      background: #f8f8f8;
      font-weight: bold;
    }
    .total-section {
      border: 1px solid #ccc;
      padding: 10px;
    }
    .total-section > div {
      display: flex;
      justify-content: space-between;
      margin-bottom: 8px;
      color: #000000;
    }
    .total-section > div:last-child {
      margin-bottom: 0;
      padding-top: 8px;
      border-top: 1px solid #ccc;
      font-weight: bold;
    }
    .no-print { display: none; }
    @media print { .no-print { display: none !important; } }
    .button-group {
      display: flex;
      gap: 8px;
      margin-bottom: 15px;
    }
    button, .button-group a {
      padding: 8px 12px;
      border: none;
      border-radius: 4px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .btn-print {
      background: #303493;
      color: white;
    }
    .btn-payment {
      background: #303493;
      color: white;
    }
    .btn-back {
      background: #f0f0f0;
      color: #000000;
      text-decoration: none;
    }
    .modal {
      display: none;
      position: fixed;
      z-index: 9999;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0,0,0,0.5);
      overflow: auto;
    }
    .modal.show {
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .modal-dialog {
      position: relative;
      width: 90%;
      max-width: 500px;
      margin: 0;
      z-index: 10000;
    }
    .modal-content {
      background-color: #ffffff;
      padding: 0;
      border-radius: 4px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.2);
      border: none;
    }
    .modal-header {
      background: #303493;
      color: white;
      padding: 16px 20px;
      border-radius: 4px 4px 0 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border: none;
    }
    .modal-title {
      font-weight: 700;
      font-size: 16px;
      margin: 0;
    }
    .btn-close {
      filter: brightness(0) invert(1);
      cursor: pointer;
      background: none;
      border: none;
      font-size: 20px;
      padding: 0;
    }
    .modal-body {
      padding: 20px;
    }
    .modal-body label {
      display: block;
      font-weight: 600;
      color: #000000;
      margin-bottom: 6px;
      font-size: 13px;
    }
    .modal-body input, .modal-body select, .modal-body textarea {
      width: 100%;
      padding: 8px 10px;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 13px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: #000000;
      margin-bottom: 12px;
    }
    .modal-body input:disabled {
      background: #f9f9f9;
      font-weight: 600;
    }
    .modal-footer {
      border-top: 1px solid #e0e0e0;
      padding: 12px 20px;
      background: #f9f9f9;
      border-radius: 0 0 4px 4px;
      display: flex;
      justify-content: flex-end;
      gap: 8px;
    }
    .modal-footer button {
      padding: 8px 16px;
      border: none;
      border-radius: 4px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
    }
    .modal-footer button.cancel {
      background: #f0f0f0;
      color: #000000;
    }
    .modal-footer button.submit {
      background: #303493;
      color: white;
    }
  </style>
</head>
<body>
<div class="voucher-container">
  <div class="button-group no-print">
    <button class="btn-print" id="printBtn"><i class="bi bi-printer"></i>Print</button>
    <% if (voucher.status === 'Pending') { %>
      <button class="btn-payment" id="addPaymentBtn">
        <i class="bi bi-plus-lg"></i>Add Payment
      </button>
    <% } %>
    <a href="javascript:history.back()" class="btn-back"><i class="bi bi-arrow-left"></i>Back</a>
  </div>

  <!-- Meta -->
  <div class="header-meta">
    <div>
      Voucher No. <strong><%= voucher.id %></strong>
      <% if (voucher.paid_on) { %> &nbsp; Paid on : <strong><%= new Date(voucher.paid_on).toLocaleString('en-IN') %></strong><% } %>
    </div>
    <div>
      Status: <strong><%= voucher.status %></strong>
      <% if (voucher.status === 'Paid') { %> by <strong><%= voucher.payment_method || 'Others' %></strong>
        <% if (voucher.payment_notes) { %> &mdash; <%= voucher.payment_notes %><% } %>
      <% } %>
    </div>
  </div>

  <!-- From / To -->
  <table class="from-to-table">
    <tr>
      <td>
        <img src="/images/logo.png" alt="Logo" class="union-logo" onerror="this.style.display='none'">
        <div><strong>From:</strong></div>
        <div><strong>South Indian Cine, Television Artistes and Dubbing Artistes Union</strong></div>
        <div>ESTD : <strong>1983</strong> - Regd No. <strong>1337/MDS</strong></div>
        <div>Affiliated with <strong>FEFSI</strong></div>
        <div>10, Vijayaraghavapuram 4th Street, Saligamam, Chennai-600093.</div>
        <div>044-23650223, 23650225, 23650229</div>
        <div>sictadau@gmail.com</div>
      </td>
      <td>
        <div><strong>To:</strong></div>
        <div><strong><%= voucher.full_name %></strong></div>
        <div>Member ID : <strong><%= voucher.member_id %></strong></div>
        <% if (voucher.address) { %><div><%= voucher.address %></div><% } %>
        <% if (voucher.email) { %><div>Email: <%= voucher.email %></div><% } %>
        <% if (voucher.contact_no || voucher.whatsapp_no) { %><div>Phone: <%= [voucher.contact_no, voucher.whatsapp_no].filter(Boolean).join(', ') %></div><% } %>
        <% if (voucher.bank_account_no) { %><div>Account No.: <strong><%= voucher.bank_account_no %></strong></div><% } %>
        <% if (voucher.ifsc_code) { %><div>IFSC.: <strong><%= voucher.ifsc_code %></strong></div><% } %>
        <% if (voucher.bank_name) { %><div>Bank Name: <strong><%= voucher.bank_name %></strong></div><% } %>
      </td>
    </tr>
  </table>

  <!-- Voucher line items -->
  <table class="data-table mb-3">
    <thead>
      <tr>
        <th>Project ID</th>
        <th>Movie Name</th>
        <th>Production Company</th>
        <th>Representative</th>
        <th>Character</th>
        <th style="text-align: right;">Total Amount</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><%= voucher.project_id %></td>
        <td><%= voucher.film_name %><% if(voucher.language) { %> (<%= voucher.language %>)<% } %></td>
        <td><%= voucher.production_company %></td>
        <td><%= voucher.rep_name || '—' %></td>
        <td><%= voucher.character || '—' %></td>
        <td style="text-align: right;">Rs. <%= (voucher.amount||0).toLocaleString('en-IN') %></td>
      </tr>
    </tbody>
  </table>

  <!-- Total calculation -->
  <div style="text-align: right; margin-bottom: 20px;">
    <div class="total-section" style="max-width: 300px; margin-left: auto;">
      <div>
        <span>Total Amount</span>
        <strong>Rs. <%= (voucher.amount||0).toLocaleString('en-IN') %></strong>
      </div>
      <div>
        <span>General Welfare Fund <%= voucher.gw_fund_percent %>%</span>
        <span>Rs. <%= (voucher.gw_fund_amount||0).toLocaleString('en-IN') %></span>
      </div>
      <div>
        <span>Representative <%= voucher.representative_percent %>%</span>
        <span>Rs. <%= (voucher.representative_amount||0).toLocaleString('en-IN') %></span>
      </div>
      <div>
        <strong>Total</strong>
        <strong>Rs. <%= (voucher.final_amount||0).toLocaleString('en-IN') %></strong>
      </div>
    </div>
  </div>

  <!-- Signatures -->
  <div style="display: flex; justify-content: space-between; margin-top: 40px; text-align: center; font-size: 12px;">
    <div>Manager / Secretary / Treasurer</div>
    <div>[ <%= voucher.full_name %> (<%= voucher.member_id %>) ]</div>
  </div>
</div>

<!-- Add Payment Modal -->
<div class="modal" id="addPaymentModal">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add Payment</h5>
        <button type="button" class="btn-close" id="closeModalBtn" aria-label="Close"></button>
      </div>
      <form id="addPaymentForm" action="/vouchers/<%= voucher.id %>/pay" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-body">
          <label for="paymentMethod">Payment Method *</label>
          <select id="paymentMethod" name="payment_method" required>
            <option value="">-- Select Payment Method --</option>
            <option value="Cash">Cash</option>
            <option value="Cheque">Cheque</option>
            <option value="NEFT">NEFT</option>
            <option value="RTGS">RTGS</option>
            <option value="Others">Others</option>
          </select>

          <label for="paymentAmount">Amount (₹) *</label>
          <input type="text" id="paymentAmount" value="₹<%= (voucher.final_amount||0).toLocaleString('en-IN') %>" disabled>
          <input type="hidden" name="amount" value="<%= voucher.final_amount %>">

          <!-- Cheque-specific fields -->
          <div id="chequeFields" style="display: none;">
            <label for="chequeNumber">Cheque Number *</label>
            <input type="text" id="chequeNumber" name="cheque_number" placeholder="Enter cheque number">

            <label for="chequeDate">Cheque Date *</label>
            <input type="date" id="chequeDate" name="cheque_date">

            <label for="chequeBank">Bank Name</label>
            <input type="text" id="chequeBank" name="cheque_bank" placeholder="Bank name">
          </div>

          <!-- NEFT/RTGS-specific fields -->
          <div id="transferFields" style="display: none;">
            <label for="transactionId">Transaction ID / UTR *</label>
            <input type="text" id="transactionId" name="transaction_id" placeholder="Enter transaction ID or UTR">

            <label for="transferBank">Bank Name</label>
            <input type="text" id="transferBank" name="transfer_bank" placeholder="Bank name">
          </div>

          <label for="paymentNotes">Notes / Reference</label>
          <textarea id="paymentNotes" name="payment_notes" rows="3" placeholder="Add any payment references or notes..."></textarea>
        </div>
        <div class="modal-footer">
          <button type="button" class="cancel" id="cancelBtn">Cancel</button>
          <button type="submit" class="submit">Add Payment</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // DOM Elements
  const modal = document.getElementById('addPaymentModal');
  const printBtn = document.getElementById('printBtn');
  const addPaymentBtn = document.getElementById('addPaymentBtn');
  const closeModalBtn = document.getElementById('closeModalBtn');
  const cancelBtn = document.getElementById('cancelBtn');
  const paymentMethodSelect = document.getElementById('paymentMethod');
  const addPaymentForm = document.getElementById('addPaymentForm');
  const chequeFields = document.getElementById('chequeFields');
  const transferFields = document.getElementById('transferFields');

  // Print button
  if (printBtn) {
    printBtn.addEventListener('click', function() {
      window.print();
    });
  }

  // Open modal
  if (addPaymentBtn) {
    addPaymentBtn.addEventListener('click', function() {
      modal.classList.add('show');
    });
  }

  // Close modal buttons
  if (closeModalBtn) {
    closeModalBtn.addEventListener('click', function() {
      modal.classList.remove('show');
    });
  }

  if (cancelBtn) {
    cancelBtn.addEventListener('click', function() {
      modal.classList.remove('show');
    });
  }

  // Close modal when clicking outside
  modal.addEventListener('click', function(event) {
    if (event.target === this) {
      this.classList.remove('show');
    }
  });

  // Show/hide conditional fields based on payment method
  function updatePaymentFields() {
    const method = paymentMethodSelect.value;

    // Hide all conditional fields
    chequeFields.style.display = 'none';
    transferFields.style.display = 'none';

    // Clear conditional field values
    document.getElementById('chequeNumber').value = '';
    document.getElementById('chequeDate').value = '';
    document.getElementById('chequeBank').value = '';
    document.getElementById('transactionId').value = '';
    document.getElementById('transferBank').value = '';

    // Show relevant fields based on selected method
    if (method === 'Cheque') {
      chequeFields.style.display = 'block';
      document.getElementById('chequeNumber').required = true;
      document.getElementById('chequeDate').required = true;
    } else if (['NEFT', 'RTGS'].includes(method)) {
      transferFields.style.display = 'block';
      document.getElementById('transactionId').required = true;
    } else {
      // Cash, Others, or no selection
      document.getElementById('chequeNumber').required = false;
      document.getElementById('chequeDate').required = false;
      document.getElementById('transactionId').required = false;
    }
  }

  // Payment method change event
  paymentMethodSelect.addEventListener('change', updatePaymentFields);

  // Form submission - validate required fields based on payment method
  addPaymentForm.addEventListener('submit', function(e) {
    const method = paymentMethodSelect.value;

    if (!method) {
      e.preventDefault();
      alert('Please select a payment method');
      return false;
    }

    if (method === 'Cheque') {
      if (!document.getElementById('chequeNumber').value.trim()) {
        e.preventDefault();
        alert('Please enter cheque number');
        return false;
      }
      if (!document.getElementById('chequeDate').value) {
        e.preventDefault();
        alert('Please select cheque date');
        return false;
      }
    }

    if (['NEFT', 'RTGS'].includes(method)) {
      if (!document.getElementById('transactionId').value.trim()) {
        e.preventDefault();
        alert('Please enter transaction ID / UTR');
        return false;
      }
    }
  });
</script>

</body>
</html>
