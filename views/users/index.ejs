<% activePage = 'users'; %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0">User Management</h4>
    <small class="text-muted"><%= users.length %>/3 accounts used</small>
  </div>
  <% if (users.length < 3) { %>
    <a href="/users/create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New User</a>
  <% } %>
</div>

<div class="row g-3">
  <% users.forEach(u => { %>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center gap-3 mb-3">
          <div style="width:50px;height:50px;border-radius:50%;background:#dbeafe;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:#1d4ed8;">
            <i class="bi bi-person"></i>
          </div>
          <div>
            <div class="fw-semibold"><%= u.name %></div>
            <div class="small text-muted"><%= u.email %></div>
          </div>
        </div>
        <div class="d-flex justify-content-between mb-2">
          <span class="small text-muted">Role</span>
          <span class="badge <%= u.role === 'superadmin' ? 'bg-danger' : u.role === 'admin' ? 'bg-primary' : 'bg-secondary' %> text-capitalize"><%= u.role %></span>
        </div>
        <div class="d-flex justify-content-between mb-2">
          <span class="small text-muted">Status</span>
          <span class="badge <%= u.is_active ? 'badge-active' : 'badge-cancelled' %>"><%= u.is_active ? 'Active' : 'Inactive' %></span>
        </div>
        <div class="d-flex justify-content-between mb-3">
          <span class="small text-muted">Last Login</span>
          <span class="small"><%= u.last_login ? new Date(u.last_login).toLocaleDateString('en-IN') : 'Never' %></span>
        </div>
        <div class="d-flex gap-2">
          <a href="/users/<%= u.id %>/edit" class="btn btn-sm btn-outline-primary flex-fill">
            <i class="bi bi-pencil me-1"></i>Edit
          </a>
          <% if (u.id !== currentUser.id) { %>
          <form action="/users/<%= u.id %>" method="POST">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
            <input type="hidden" name="_method" value="DELETE">
            <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="Delete user '<%= u.name %>'?">
              <i class="bi bi-trash"></i>
            </button>
          </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <% }) %>
</div>

<div class="alert alert-info mt-4 small">
  <i class="bi bi-shield-check me-2"></i>
  <strong>Security Note:</strong> Maximum 3 user accounts allowed. Roles: <strong>superadmin</strong> (full access), <strong>admin</strong> (manage all modules), <strong>staff</strong> (read + create, no delete).
</div>
