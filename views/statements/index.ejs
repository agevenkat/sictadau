<% activePage = 'statements'; %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0">Statement</h4>
    <small class="text-muted">
      Credit: <span class="text-success fw-medium">₹<%= Math.round(totals.total_credit||0).toLocaleString('en-IN') %></span> &bull;
      Debit: <span class="text-danger fw-medium">₹<%= Math.round(totals.total_debit||0).toLocaleString('en-IN') %></span> &bull;
      Balance: <span class="<%= balance >= 0 ? 'text-success' : 'text-danger' %> fw-bold">₹<%= Math.round(Math.abs(balance)).toLocaleString('en-IN') %> <%= balance >= 0 ? 'Cr' : 'Dr' %></span>
    </small>
  </div>
  <div class="d-flex gap-2">
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addExpenseModal">
      <i class="bi bi-plus-lg me-1"></i>Add Expense
    </button>
    <button class="btn btn-outline-success btn-sm" data-bs-toggle="modal" data-bs-target="#addIncomeModal">
      <i class="bi bi-plus-lg me-1"></i>Add Income
    </button>
  </div>
</div>

<!-- Filters -->
<div class="card mb-3 border-0 shadow-sm">
  <div class="card-body py-2">
    <form class="row g-2 align-items-end" method="GET">
      <div class="col-md-3">
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Search..." value="<%= search %>">
      </div>
      <div class="col-md-2">
        <select name="type" class="form-select form-select-sm">
          <option value="">All</option>
          <option value="Debit" <%= type === 'Debit' ? 'selected' : '' %>>Debit</option>
          <option value="Credit" <%= type === 'Credit' ? 'selected' : '' %>>Credit</option>
        </select>
      </div>
      <div class="col-md-2">
        <input type="date" name="from" id="stmtFrom" class="form-control form-control-sm" value="<%= from %>" placeholder="From">
      </div>
      <div class="col-md-2">
        <input type="date" name="to" id="stmtTo" class="form-control form-control-sm" value="<%= to %>" placeholder="To">
      </div>
      <div class="col-auto">
        <button class="btn btn-sm btn-primary">Filter</button>
        <a href="/statements" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
      </div>
      <div class="col-12 mt-1">
        <div class="btn-group btn-group-sm" role="group">
          <button type="button" class="btn btn-outline-secondary" onclick="stmtDatePreset('today')">Today</button>
          <button type="button" class="btn btn-outline-secondary" onclick="stmtDatePreset('week')">This Week</button>
          <button type="button" class="btn btn-outline-secondary" onclick="stmtDatePreset('month')">This Month</button>
          <button type="button" class="btn btn-outline-secondary" onclick="stmtDatePreset('lastmonth')">Last Month</button>
          <button type="button" class="btn btn-outline-secondary" onclick="stmtDatePreset('year')">This Year</button>
        </div>
      </div>
    </form>
    <small class="text-muted d-block mt-2"><i class="bi bi-info-circle"></i> Click column headers to sort &bull; Default: Latest first</small>
  </div>
</div>

<div class="table-card card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table id="stmtTable" class="table table-hover mb-0">
        <thead>
          <tr>
            <th>Transaction Date</th>
            <th>Income Type</th>
            <th>Paid To</th>
            <th>Movie Name</th>
            <th>Payment Mode</th>
            <th>Transaction Remarks</th>
            <th>Amount Type</th>
            <th>Amount</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Expense Modal -->
<div class="modal fade" id="addExpenseModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add Expense</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/statements" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="amount_type" value="Debit">
        <div class="modal-body">
          <%- include('../partials/statement_form', { isCredit: false }) %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-danger">Add Expense</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Add Income Modal -->
<div class="modal fade" id="addIncomeModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add Income</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/statements" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="amount_type" value="Credit">
        <div class="modal-body">
          <%- include('../partials/statement_form', { isCredit: true }) %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success">Add Income</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function stmtDatePreset(preset) {
  function fmtLocal(d) {
    var y = d.getFullYear();
    var m = String(d.getMonth() + 1).padStart(2, '0');
    var day = String(d.getDate()).padStart(2, '0');
    return y + '-' + m + '-' + day;
  }
  var now = new Date();
  var from, to = fmtLocal(now);
  if (preset === 'today') {
    from = fmtLocal(now);
  } else if (preset === 'week') {
    var dow = now.getDay() || 7;
    var mon = new Date(now); mon.setDate(now.getDate() - (dow - 1));
    from = fmtLocal(mon);
  } else if (preset === 'month') {
    from = fmtLocal(new Date(now.getFullYear(), now.getMonth(), 1));
  } else if (preset === 'lastmonth') {
    from = fmtLocal(new Date(now.getFullYear(), now.getMonth() - 1, 1));
    to   = fmtLocal(new Date(now.getFullYear(), now.getMonth(), 0));
  } else if (preset === 'year') {
    from = fmtLocal(new Date(now.getFullYear(), 0, 1));
  }
  document.getElementById('stmtFrom').value = from;
  document.getElementById('stmtTo').value   = to;
  document.getElementById('stmtFrom').closest('form').submit();
}

(function(){
  const SEARCH = <%- JSON.stringify(search) %>;
  const TYPE   = <%- JSON.stringify(type) %>;
  const FROM   = <%- JSON.stringify(from) %>;
  const TO     = <%- JSON.stringify(to) %>;

  function escHtml(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  // Parse YYYY-MM-DD prefix directly — avoids UTC-midnight timezone shift in IST browsers
  function fmtDate(d) {
    if (!d) return '—';
    var m = String(d).match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (!m) return String(d);
    var mon = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return m[3] + '-' + mon[parseInt(m[2])-1] + '-' + m[1];
  }

  $('#stmtTable').DataTable({
    serverSide: true,
    processing: true,
    searching: false,
    ajax: {
      url: '/statements/data',
      data: function(d) {
        d.search.value = SEARCH;
        d.type = TYPE;
        d.from = FROM;
        d.to   = TO;
      }
    },
    columns: [
      { data: 'transaction_date_f', className: 'small', defaultContent: '—' },
      { data: 'income_type', className: 'small', render: function(d) { return d ? escHtml(d) : '—'; } },
      { data: 'paid_to', className: 'small', render: function(d) { return d ? escHtml(d) : '—'; } },
      { data: 'film_name', className: 'small text-muted', render: function(d) { return d ? escHtml(d) : '—'; } },
      { data: 'payment_mode', className: 'small', render: function(d) { return d ? escHtml(d) : '—'; } },
      { data: 'transaction_remarks', className: 'small text-muted', render: function(d) { return d ? escHtml(d) : '—'; } },
      {
        data: 'amount_type', orderable: false,
        render: function(d) {
          return '<span class="badge ' + (d === 'Debit' ? 'bg-danger' : 'bg-success') + '">' + escHtml(d) + '</span>';
        }
      },
      {
        data: null,
        render: function(row) {
          var cls = row.amount_type === 'Debit' ? 'text-danger' : 'text-success';
          return '<span class="small fw-medium ' + cls + '">Rs. ' + (Number(row.amount)||0).toLocaleString('en-IN') + '</span>';
        }
      },
      {
        data: null, orderable: false,
        render: function(row) {
          var btn = '';
          if (row.receipt) {
            btn += '<a href="/statements/' + row.id + '/receipt" class="btn btn-xs btn-outline-primary me-1" style="font-size:0.75rem;padding:2px 6px;" target="_blank">View Receipt</a>';
          }
          btn += '<a href="/statements/' + row.id + '/receipt" class="btn btn-xs btn-outline-secondary" style="font-size:0.75rem;padding:2px 6px;" target="_blank">View</a>';
          return btn;
        }
      }
    ],
    order: [[0, 'desc']],
    pageLength: 25,
    lengthMenu: [[25, 50, 100], ['25', '50', '100']],
    pagingType: 'simple_numbers',
    dom: "<'row mb-2'<'col-sm-12 col-md-6'B><'col-sm-6 col-md-6'l>>" +
         "<'row'<'col-sm-12'tr>>" +
         "<'row mt-2 align-items-center'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7 d-flex justify-content-end'p>>",
    buttons: [
      {
        text: '<i class="bi bi-file-earmark-csv me-1"></i>Export CSV',
        className: 'btn btn-sm btn-outline-secondary',
        action: function() {
          window.location.href = '/statements/export?' + new URLSearchParams({search: SEARCH, type: TYPE, from: FROM, to: TO}).toString();
        }
      }
    ],
    language: {
      processing: '<span class="spinner-border spinner-border-sm text-primary me-1" role="status"></span> Loading...',
      lengthMenu: '_MENU_ per page',
      info: 'Showing _START_–_END_ of _TOTAL_',
      infoEmpty: 'No records found',
      infoFiltered: '(filtered)',
      paginate: { first: '«', last: '»', next: '›', previous: '‹' }
    }
  });
})();
</script>
