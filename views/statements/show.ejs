<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Receipt #<%= stmt.id %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>@media print { .no-print{display:none!important} }</style>
</head>
<body>
<div class="container py-4" style="max-width:600px;">
  <div class="no-print mb-3 d-flex gap-2">
    <button onclick="window.print()" class="btn btn-sm btn-dark"><i class="bi bi-printer me-1"></i>Print</button>
    <a href="javascript:history.back()" class="btn btn-sm btn-outline-secondary">Back</a>
  </div>

  <div class="card shadow-sm">
    <div class="card-header bg-dark text-white d-flex justify-content-between">
      <span><strong>SICTADAU</strong> — Transaction Receipt</span>
      <span>#<%= stmt.id %></span>
    </div>
    <div class="card-body">
      <div class="row g-2 mb-3">
        <div class="col-6"><small class="text-muted">Date</small><div class="fw-medium"><%= stmt.transaction_date %></div></div>
        <div class="col-6"><small class="text-muted">Type</small><div><span class="badge <%= stmt.amount_type === 'Debit' ? 'bg-danger' : 'bg-success' %>"><%= stmt.amount_type %></span></div></div>
        <div class="col-6"><small class="text-muted">Income Type</small><div><%= stmt.income_type || '—' %></div></div>
        <div class="col-6"><small class="text-muted">Payment Mode</small><div><%= stmt.payment_mode || '—' %></div></div>
        <div class="col-6"><small class="text-muted">Paid To / From</small><div><%= stmt.paid_to || '—' %></div></div>
        <div class="col-6"><small class="text-muted">Project</small><div><%= stmt.film_name || '—' %></div></div>
        <div class="col-12"><small class="text-muted">Remarks</small><div><%= stmt.transaction_remarks || '—' %></div></div>
      </div>
      <div class="border-top pt-3">
        <div class="d-flex justify-content-between fs-5">
          <span class="fw-bold">Amount</span>
          <span class="fw-bold <%= stmt.amount_type === 'Debit' ? 'text-danger' : 'text-success' %>">
            ₹<%= (stmt.amount||0).toLocaleString('en-IN') %>
          </span>
        </div>
      </div>
      <% if (stmt.receipt) { %>
      <div class="mt-3">
        <a href="<%= stmt.receipt %>" target="_blank" class="btn btn-sm btn-outline-primary"><i class="bi bi-file-earmark me-1"></i>View Receipt File</a>
      </div>
      <% } %>
    </div>
    <div class="card-footer text-muted small text-center">
      South Indian Cine, Television Artistes and Dubbing Artistes Union — ESTD 1983
    </div>
  </div>
</div>
</body>
</html>
