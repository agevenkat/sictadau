<% activePage = 'members'; %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0">All Members</h4>
    <small class="text-muted"><%= stats.total %> total &bull; <%= stats.active %> active &bull; <%= stats.expired %> expired</small>
  </div>
  <a href="/members/create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Member</a>
</div>

<!-- Quick filter -->
<div class="card mb-3 border-0 shadow-sm">
  <div class="card-body py-2">
    <form class="row g-2 align-items-end" method="GET" id="filterForm">
      <div class="col-md-5">
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Search name, membership no, contact..." value="<%= search %>">
      </div>
      <div class="col-md-3">
        <select name="status" class="form-select form-select-sm">
          <option value="">All Status</option>
          <% ['Active','Expired','Cancelled'].forEach(s => { %>
            <option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-auto">
        <button class="btn btn-sm btn-primary">Filter</button>
        <a href="/members" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
      </div>
    </form>
    <small class="text-muted d-block mt-2"><i class="bi bi-info-circle"></i> Click column headers to sort &bull; Showing one page at a time for speed</small>
  </div>
</div>

<div class="table-card card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table id="membersTable" class="table table-hover mb-0">
        <thead>
          <tr>
            <th>M.No</th>
            <th>Photo</th>
            <th>Name</th>
            <th>C.No</th>
            <th>L.Known</th>
            <th>Slang</th>
            <th>Gender</th>
            <th>DOB</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </div>
</div>

<script>
(function(){
  const SEARCH = <%- JSON.stringify(search) %>;
  const STATUS = <%- JSON.stringify(status) %>;

  function escHtml(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  // Parse YYYY-MM-DD prefix directly — avoids UTC-midnight timezone shift in IST browsers
  function fmtDate(d) {
    if (!d) return '—';
    var m = String(d).match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (!m) return String(d);
    var mon = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return m[3] + '-' + mon[parseInt(m[2])-1] + '-' + m[1];
  }

  $('#membersTable').DataTable({
    serverSide: true,
    processing: true,
    searching: false,
    ajax: {
      url: '/members/data',
      data: function(d) {
        d.search.value = SEARCH;
        d.status = STATUS;
      }
    },
    columns: [
      { data: 'membership_no', className: 'text-muted small' },
      {
        data: 'profile_picture', orderable: false,
        render: function(data) {
          if (data) return '<img src="' + escHtml(data) + '" class="member-photo" alt="">';
          return '<div class="member-photo-placeholder"><i class="bi bi-person"></i></div>';
        }
      },
      {
        data: null, render: function(row) {
          return '<a href="/members/' + row.id + '" class="fw-medium text-decoration-none">' + escHtml(row.full_name) + '</a>';
        }
      },
      { data: 'contact_no', className: 'small text-muted', render: function(d) { return d || '—'; } },
      {
        data: 'languages', orderable: false, className: 'small',
        render: function(data) {
          try { var l = JSON.parse(data || '[]'); return l.length ? escHtml(l.join(', ')) : '—'; } catch(e) { return data || '—'; }
        }
      },
      { data: 'slang', className: 'small', render: function(d) { return d ? escHtml(d) : '—'; } },
      { data: 'gender', className: 'small', render: function(d) { return d || '—'; } },
      { data: 'dob', className: 'small', render: function(d) { return fmtDate(d); } },
      {
        data: 'status',
        render: function(d) {
          return '<span class="badge badge-' + d.toLowerCase() + '">' + escHtml(d) + '</span>';
        }
      },
      {
        data: null, orderable: false,
        render: function(row) {
          return '<div class="d-flex gap-1"><a href="/members/' + row.id + '/edit" class="btn btn-xs btn-outline-secondary" style="font-size:0.75rem;padding:2px 8px;" title="Edit"><i class="bi bi-pencil"></i></a></div>';
        }
      }
    ],
    order: [[0, 'asc']],
    pageLength: 25,
    lengthMenu: [[25, 50, 100], ['25', '50', '100']],
    pagingType: 'simple_numbers',
    dom: "<'row mb-2'<'col-sm-12 col-md-6'B><'col-sm-6 col-md-6'l>>" +
         "<'row'<'col-sm-12'tr>>" +
         "<'row mt-2 align-items-center'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7 d-flex justify-content-end'p>>",
    buttons: [
      {
        text: '<i class="bi bi-file-earmark-csv me-1"></i>Export CSV',
        className: 'btn btn-sm btn-outline-secondary',
        action: function() {
          window.location.href = '/members/export?' + new URLSearchParams({search: SEARCH, status: STATUS}).toString();
        }
      }
    ],
    language: {
      processing: '<span class="spinner-border spinner-border-sm text-primary me-1" role="status"></span> Loading...',
      lengthMenu: '_MENU_ per page',
      info: 'Showing _START_–_END_ of _TOTAL_',
      infoEmpty: 'No records found',
      infoFiltered: '(filtered)',
      paginate: { first: '«', last: '»', next: '›', previous: '‹' }
    }
  });
})();
</script>
