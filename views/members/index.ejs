<% activePage = 'members'; %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0">All Members</h4>
    <small class="text-muted"><%= stats.total %> total &bull; <%= stats.active %> active &bull; <%= stats.expired %> expired</small>
  </div>
  <a href="/members/create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Member</a>
</div>

<!-- Quick filter -->
<div class="card mb-3 border-0 shadow-sm">
  <div class="card-body py-2">
    <form class="row g-2 align-items-end" method="GET">
      <div class="col-md-5">
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Search name, membership no, contact..." value="<%= search %>">
      </div>
      <div class="col-md-3">
        <select name="status" class="form-select form-select-sm">
          <option value="">All Status</option>
          <% ['Active','Expired','Cancelled'].forEach(s => { %>
            <option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-auto">
        <button class="btn btn-sm btn-primary">Filter</button>
        <a href="/members" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
      </div>
    </form>
    <small class="text-muted d-block mt-2"><i class="bi bi-info-circle"></i> Click column headers to sort • Sort options appear on all columns</small>
  </div>
</div>

<div class="table-card card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table id="membersTable" class="table table-hover mb-0">
        <thead>
          <tr>
            <th>M.No</th>
            <th>Photo</th>
            <th>Name</th>
            <th>C.No</th>
            <th>L.Known</th>
            <th>Slang</th>
            <th>Gender</th>
            <th>DOB</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% members.forEach(m => { %>
          <tr>
            <td class="text-muted small"><%= m.membership_no %></td>
            <td>
              <% if (m.profile_picture) { %>
                <img src="<%= m.profile_picture %>" class="member-photo" alt="">
              <% } else { %>
                <div class="member-photo-placeholder"><i class="bi bi-person"></i></div>
              <% } %>
            </td>
            <td><a href="/members/<%= m.id %>" class="fw-medium text-decoration-none"><%= m.full_name %></a></td>
            <td class="small text-muted"><%= m.contact_no || '—' %></td>
            <td class="small">
              <% try { const langs = JSON.parse(m.languages || '[]'); %><%= langs.join(', ') || '—' %><% } catch(e) { %><%= m.languages || '—' %><% } %>
            </td>
            <td class="small"><%= m.slang || '—' %></td>
            <td class="small"><%= m.gender || '—' %></td>
            <td class="small"><%= m.dob ? m.dob.split(' ')[0] : '—' %></td>
            <td>
              <span class="badge badge-<%= m.status.toLowerCase() %>"><%= m.status %></span>
            </td>
            <td>
              <div class="d-flex gap-1">
                <a href="/members/<%= m.id %>/edit" class="btn btn-xs btn-outline-secondary" style="font-size:0.75rem;padding:2px 8px;" title="Edit"><i class="bi bi-pencil"></i></a>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
$(function(){
  initDataTable('#membersTable', {
    order: [[0, 'asc']],
    columnDefs: [
      { orderable: false, targets: [1, 9] },
      {
        targets: [1, 5, 6, 7],
        visible: true,
        responsivePriority: 10000
      },
      { responsivePriority: 1, targets: [2, 8] }
    ]
  });
});
</script>
