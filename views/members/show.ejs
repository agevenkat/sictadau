<% activePage = 'members'; %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0"><%= member.full_name %></h4>
    <small class="text-muted">Member No: <%= member.membership_no %></small>
  </div>
  <div class="d-flex gap-2">
    <a href="/members/<%= member.id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil me-1"></i>Edit</a>
    <form action="/members/<%= member.id %>" method="POST" class="d-inline">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <input type="hidden" name="_method" value="DELETE">
      <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="Delete this member permanently?">
        <i class="bi bi-trash me-1"></i>Delete
      </button>
    </form>
    <a href="/members" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm text-center p-4">
      <% if (member.profile_picture) { %>
        <img src="<%= member.profile_picture %>" alt="<%= member.full_name %>" style="width:120px;height:120px;border-radius:50%;object-fit:cover;margin:0 auto 1rem;" class="border">
      <% } else { %>
        <div style="width:120px;height:120px;border-radius:50%;background:#e5e7eb;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:3rem;color:#9ca3af;">
          <i class="bi bi-person"></i>
        </div>
      <% } %>
      <h5 class="fw-bold"><%= member.full_name %></h5>
      <span class="badge badge-<%= member.status.toLowerCase() %> px-3 py-2 mb-2"><%= member.status %></span>
      <div class="text-muted small"><%= member.member_type %> Member</div>
    </div>
  </div>

  <div class="col-md-8">
    <div class="row g-3">
      <div class="col-12">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <div class="form-section-title">Personal Details</div>
            <div class="row g-2">
              <% const fields = [
                ['Membership No', member.membership_no], ['Gender', member.gender],
                ['Date of Birth', member.dob ? member.dob.split(' ')[0] : null], ['Blood Group', member.blood_group],
                ['Contact No', member.contact_no], ['Whatsapp', member.whatsapp_no],
                ['Email', member.email], ['Admission Year', member.admission_year],
                ['Languages', member.languages.join(', ')], ['Slang', member.slang],
                ['Qualification', member.qualification], ['Experience', member.years_experience ? member.years_experience + ' yrs' : null],
                ['Family Members', member.family_members], ['Nominee', member.nominee]
              ]; %>
              <% fields.forEach(([label, val]) => { if (!val) return; %>
              <div class="col-md-6">
                <div class="small text-muted"><%= label %></div>
                <div class="small fw-medium"><%= val %></div>
              </div>
              <% }) %>
              <% if (member.address) { %>
              <div class="col-12">
                <div class="small text-muted">Address</div>
                <div class="small"><%= member.address %></div>
              </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <div class="form-section-title">Bank Details</div>
            <div class="row g-2">
              <% [['Bank Name', member.bank_name], ['Account No', member.bank_account_no], ['IFSC', member.ifsc_code], ['Aadhaar', member.aadhaar_no]].forEach(([label, val]) => { %>
              <div class="col-md-6">
                <div class="small text-muted"><%= label %></div>
                <div class="small fw-medium"><%= val || '—' %></div>
              </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Voucher Payment Summary -->
  <div class="col-12">
    <div class="row g-3 mb-1">
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
          <div class="fw-bold fs-5 text-primary"><%= voucherStats.total %></div>
          <div class="small text-muted">Total Vouchers</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
          <div class="fw-bold fs-5 text-success"><%= voucherStats.paid %></div>
          <div class="small text-muted">Paid</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
          <div class="fw-bold fs-5 text-warning"><%= voucherStats.pending %></div>
          <div class="small text-muted">Pending</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
          <div class="fw-bold fs-6 text-success">₹<%= Math.round(voucherStats.total_paid_amount).toLocaleString('en-IN') %></div>
          <div class="small text-muted">Total Disbursed</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ Membership Fees ══════════════════════════════════════════════ -->
  <div class="col-12" id="fees">

    <!-- Fee KPI row -->
    <%
      const feeTotalPaid = feeStats.total_paid || 0;
      const feeLastYear  = feeStats.last_year  || null;
      const currentYear  = new Date().getFullYear();
    %>
    <div class="row g-2 mb-2">
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
          <div class="fw-bold fs-5 text-primary"><%= feeStats.total_entries || 0 %></div>
          <div class="small text-muted">Fee Entries</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
          <div class="fw-bold fs-6 text-success">₹<%= feeTotalPaid.toLocaleString('en-IN') %></div>
          <div class="small text-muted">Total Collected</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
          <div class="fw-bold fs-5 <%= feeLastYear >= currentYear ? 'text-success' : 'text-danger' %>">
            <%= feeLastYear || '—' %>
          </div>
          <div class="small text-muted">Last Paid Year</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
          <% if (!feeLastYear || feeLastYear < currentYear) { %>
            <div class="fw-bold fs-6 text-danger"><i class="bi bi-exclamation-circle"></i> Overdue</div>
          <% } else { %>
            <div class="fw-bold fs-6 text-success"><i class="bi bi-check-circle"></i> Up to Date</div>
          <% } %>
          <div class="small text-muted"><%= currentYear %> Status</div>
        </div>
      </div>
    </div>

    <!-- Fee table -->
    <div class="table-card card mb-3">
      <div class="card-header d-flex justify-content-between align-items-center py-2">
        <span class="fw-semibold"><i class="bi bi-card-checklist me-1 text-primary"></i>Membership Fees</span>
        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#feeModal">
          <i class="bi bi-plus-lg me-1"></i>Record Fee
        </button>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead>
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th class="text-center">Year</th>
              <th>Mode</th>
              <th>Receipt No.</th>
              <th class="text-end">Amount</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (fees.length === 0) { %>
            <tr><td colspan="7" class="text-center text-muted py-3 small">
              No fee entries yet. Use "Record Fee" to add one.
            </td></tr>
            <% } else {
              const MON2 = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
              function fmtFeeDate(d) {
                if (!d) return '—';
                const m = String(d).match(/(\d{4})-(\d{2})-(\d{2})/);
                return m ? m[3]+'-'+MON2[parseInt(m[2])-1]+'-'+m[1] : String(d);
              }
            %>
            <% fees.forEach(f => { %>
            <tr>
              <td class="small text-muted"><%= fmtFeeDate(f.payment_date) %></td>
              <td class="small fw-medium"><%= f.fee_type %></td>
              <td class="text-center small"><%= f.year || '—' %></td>
              <td class="small text-muted"><%= f.payment_mode %></td>
              <td class="small text-muted"><%= f.receipt_no || '—' %></td>
              <td class="text-end small fw-bold text-success">₹<%= (f.amount||0).toLocaleString('en-IN') %></td>
              <td class="text-center">
                <form action="/members/<%= member.id %>/fees/<%= f.id %>" method="POST" class="d-inline"
                      onsubmit="return confirm('Delete this fee entry? The Statement ledger entry will remain.')">
                  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <input type="hidden" name="_method" value="DELETE">
                  <button type="submit" class="btn btn-xs btn-outline-danger" style="font-size:.7rem;padding:2px 6px;" title="Delete">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Legacy: name-matched statement entries -->
    <% if (legacyFees.length > 0) { %>
    <div class="card border-0 shadow-sm border-warning" style="border-left:3px solid #f59e0b !important;">
      <div class="card-header py-2 d-flex justify-content-between align-items-center" style="background:#fffbeb;">
        <span class="small fw-semibold text-warning-emphasis">
          <i class="bi bi-clock-history me-1"></i>Earlier entries from Statement ledger
          <span class="badge bg-warning text-dark ms-1"><%= legacyFees.length %></span>
        </span>
        <span class="small text-muted fst-italic">Matched by member name — may not be 100% accurate</span>
      </div>
      <div class="table-responsive">
        <table class="table table-sm mb-0">
          <thead class="table-warning">
            <tr>
              <th>Date</th>
              <th>Remarks</th>
              <th>Mode</th>
              <th class="text-end">Amount</th>
            </tr>
          </thead>
          <tbody>
            <% legacyFees.forEach(lf => { %>
            <tr>
              <td class="small text-muted"><%= fmtFeeDate(lf.transaction_date) %></td>
              <td class="small"><%= lf.transaction_remarks || '—' %></td>
              <td class="small text-muted"><%= lf.payment_mode || '—' %></td>
              <td class="text-end small fw-medium text-success">₹<%= (lf.amount||0).toLocaleString('en-IN') %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>

  </div>
  <!-- ══ End Membership Fees ══════════════════════════════════════════ -->

  <!-- Payment History -->
  <div class="col-12">
    <div class="table-card card">
      <div class="card-header d-flex justify-content-between align-items-center py-2">
        <span class="fw-semibold">
          Payment History
          <% if (voucherStats.pending > 0) { %>
          <span class="badge bg-warning text-dark ms-1"><%= voucherStats.pending %> pending</span>
          <% } %>
        </span>
        <div class="d-flex gap-2">
          <% if (voucherStats.pending > 0) { %>
          <span class="small text-danger fw-medium">₹<%= Math.round(voucherStats.total_pending_amount).toLocaleString('en-IN') %> due</span>
          <% } %>
          <a href="/vouchers/create?member_id=<%= member.id %>" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-plus-lg me-1"></i>New Voucher
          </a>
        </div>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead><tr><th>#</th><th>Date</th><th>Project</th><th>Character</th><th>Gross</th><th>Final</th><th>Mode</th><th>Status</th><th></th></tr></thead>
          <tbody>
            <% if (vouchers.length === 0) { %>
            <tr><td colspan="9" class="text-center text-muted py-3 small">No vouchers yet</td></tr>
            <% } else { %>
            <%
              const MON = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
              function fmtVDate(d) {
                if (!d) return '—';
                const m = String(d).match(/(\d{4})-(\d{2})-(\d{2})/);
                return m ? m[3]+'-'+MON[parseInt(m[2])-1]+'-'+m[1] : String(d);
              }
            %>
            <% vouchers.forEach(v => { %>
            <tr>
              <td class="small text-muted">#<%= v.id %></td>
              <td class="small text-muted"><%= fmtVDate(v.voucher_date) %></td>
              <td class="small"><%= v.film_name %></td>
              <td class="small"><%= v.character || '—' %></td>
              <td class="small">₹<%= (v.amount||0).toLocaleString('en-IN') %></td>
              <td class="small fw-medium <%= v.status === 'Paid' ? 'text-success' : 'text-warning' %>">₹<%= (v.final_amount||0).toLocaleString('en-IN') %></td>
              <td class="small text-muted"><%= v.payment_method || '—' %></td>
              <td><span class="badge badge-<%= v.status.toLowerCase() %>"><%= v.status %></span></td>
              <td><a href="/vouchers/<%= v.id %>/show" class="btn btn-xs btn-outline-secondary" style="font-size:0.75rem;padding:2px 8px;">View</a></td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- ══ Record Fee Modal ══════════════════════════════════════════════ -->
<div class="modal fade" id="feeModal" tabindex="-1" aria-labelledby="feeModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-md">
    <form action="/members/<%= member.id %>/fees" method="POST">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title fw-bold" id="feeModalLabel">
            <i class="bi bi-card-checklist me-2 text-primary"></i>Record Membership Fee
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="small text-muted mb-3 p-2 bg-light rounded">
            <i class="bi bi-person me-1"></i><strong><%= member.full_name %></strong>
            &nbsp;·&nbsp;Membership No: <strong><%= member.membership_no %></strong>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label form-label-sm fw-medium">Fee Type <span class="text-danger">*</span></label>
              <select name="fee_type" class="form-select form-select-sm" required>
                <option value="Annual">Annual Fee</option>
                <option value="Admission">Admission Fee</option>
                <option value="Life Membership">Life Membership</option>
                <option value="Re-admission">Re-admission Fee</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label form-label-sm fw-medium">Year</label>
              <input type="number" name="year" class="form-control form-control-sm"
                value="<%= new Date().getFullYear() %>" min="1980" max="2100" placeholder="e.g. 2025">
            </div>
            <div class="col-md-6">
              <label class="form-label form-label-sm fw-medium">Amount (₹) <span class="text-danger">*</span></label>
              <input type="number" name="amount" class="form-control form-control-sm"
                step="0.01" min="1" required placeholder="0.00">
            </div>
            <div class="col-md-6">
              <label class="form-label form-label-sm fw-medium">Payment Date <span class="text-danger">*</span></label>
              <input type="date" name="payment_date" class="form-control form-control-sm"
                value="<%= new Date().toISOString().slice(0,10) %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label form-label-sm fw-medium">Payment Mode</label>
              <select name="payment_mode" class="form-select form-select-sm">
                <option value="Cash">Cash</option>
                <option value="NEFT">NEFT</option>
                <option value="Cheque">Cheque</option>
                <option value="Others">Others</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label form-label-sm fw-medium">Receipt No.</label>
              <input type="text" name="receipt_no" class="form-control form-control-sm" placeholder="Optional">
            </div>
            <div class="col-12">
              <label class="form-label form-label-sm fw-medium">Notes</label>
              <input type="text" name="notes" class="form-control form-control-sm" placeholder="Optional remarks">
            </div>
          </div>
          <div class="alert alert-info mt-3 mb-0 py-2 small">
            <i class="bi bi-info-circle me-1"></i>
            This will automatically post a <strong>Credit</strong> entry to the Statement ledger.
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-sm btn-primary">
            <i class="bi bi-check-lg me-1"></i>Record Fee
          </button>
        </div>
      </div>
    </form>
  </div>
</div>
