<% activePage = 'members'; %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-bold mb-0"><%= typeof isEdit !== 'undefined' && isEdit ? 'Edit Member' : 'New Member' %></h4>
  <a href="/members<%= typeof isEdit !== 'undefined' && isEdit ? '/' + member.id : '' %>" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i>Back
  </a>
</div>

<% if (errors && errors.length) { %>
<div class="alert alert-danger">
  <ul class="mb-0 ps-3"><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
</div>
<% } %>

<form action="/members<%= typeof isEdit !== 'undefined' && isEdit ? '/' + member.id : '' %>" method="POST" enctype="multipart/form-data">
  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <% if (typeof isEdit !== 'undefined' && isEdit) { %><input type="hidden" name="_method" value="PUT"><% } %>

  <div class="row g-3">
    <!-- Left column -->
    <div class="col-md-6">
      <div class="form-card mb-3">
        <div class="form-section-title">Basic Information</div>
        <div class="row g-2">
          <div class="col-md-5">
            <label class="form-label">Membership No <span class="text-danger">*</span></label>
            <% if (typeof isEdit !== 'undefined' && isEdit) { %>
              <input type="text" class="form-control" value="<%= member.membership_no || '' %>" disabled>
              <input type="hidden" name="membership_no" value="<%= member.membership_no || '' %>">
            <% } else { %>
              <input type="text" name="membership_no" class="form-control" value="<%= member.membership_no || '' %>" required>
            <% } %>
          </div>
          <div class="col-md-7">
            <label class="form-label">Full Name <span class="text-danger">*</span></label>
            <input type="text" name="full_name" class="form-control" value="<%= member.full_name || '' %>" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Whatsapp No</label>
            <input type="text" name="whatsapp_no" class="form-control" value="<%= member.whatsapp_no || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label">Contact No</label>
            <input type="text" name="contact_no" class="form-control" value="<%= member.contact_no || '' %>">
          </div>
          <div class="col-12">
            <label class="form-label">Address</label>
            <textarea name="address" class="form-control" rows="2"><%= member.address || '' %></textarea>
          </div>
          <div class="col-md-6">
            <label class="form-label">Slang (City/Region)</label>
            <input type="text" name="slang" class="form-control" value="<%= member.slang || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" value="<%= member.email || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label">Admission Year</label>
            <input type="number" name="admission_year" class="form-control" value="<%= member.admission_year || '' %>" min="1983" max="<%= new Date().getFullYear() %>">
          </div>
          <div class="col-md-6">
            <label class="form-label">Gender</label>
            <select name="gender" class="form-select select2-search">
              <option value="">— Select —</option>
              <% ['Male','Female','Other'].forEach(g => { %>
                <option value="<%= g %>" <%= member.gender === g ? 'selected' : '' %>><%= g %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label">Date of Birth</label>
            <input type="date" name="dob" class="form-control" value="<%= member.dob ? member.dob.split(' ')[0] : '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label">Blood Group</label>
            <select name="blood_group" class="form-select select2-search">
              <option value="">— Select —</option>
              <% BLOOD_GROUPS.forEach(b => { %>
                <option value="<%= b %>" <%= member.blood_group === b ? 'selected' : '' %>><%= b %></option>
              <% }) %>
            </select>
          </div>
        </div>
      </div>
    </div>

    <!-- Right column -->
    <div class="col-md-6">
      <div class="form-card mb-3">
        <div class="form-section-title">Professional Details</div>
        <div class="row g-2">
          <div class="col-12">
            <label class="form-label">Language(s) Known</label>
            <div class="d-flex flex-wrap gap-2 p-2 border rounded">
              <% LANGUAGES.forEach(lang => { %>
                <% const checked = Array.isArray(member.languages) ? member.languages.includes(lang) : false; %>
                <div class="form-check mb-0">
                  <input class="form-check-input" type="checkbox" name="languages" value="<%= lang %>" id="lang_<%= lang %>" <%= checked ? 'checked' : '' %>>
                  <label class="form-check-label small" for="lang_<%= lang %>"><%= lang %></label>
                </div>
              <% }) %>
            </div>
          </div>
          <div class="col-md-6">
            <label class="form-label">Qualification</label>
            <input type="text" name="qualification" class="form-control" value="<%= member.qualification || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label">Years of Experience</label>
            <input type="number" name="years_experience" class="form-control" value="<%= member.years_experience || '' %>" min="0">
          </div>
          <div class="col-md-6">
            <label class="form-label">Status</label>
            <select name="status" class="form-select select2-search">
              <% ['Active','Expired','Cancelled'].forEach(s => { %>
                <option value="<%= s %>" <%= member.status === s ? 'selected' : '' %>><%= s %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label">Member Type</label>
            <select name="member_type" class="form-select select2-search">
              <% MEMBER_TYPES.forEach(t => { %>
                <option value="<%= t %>" <%= member.member_type === t ? 'selected' : '' %>><%= t %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label">Family Members</label>
            <input type="text" name="family_members" class="form-control" value="<%= member.family_members || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label">Nominee</label>
            <input type="text" name="nominee" class="form-control" value="<%= member.nominee || '' %>">
          </div>
          <div class="col-12">
            <label class="form-label">Notes</label>
            <textarea name="notes" class="form-control" rows="2"><%= member.notes || '' %></textarea>
          </div>
        </div>
      </div>

      <div class="form-card mb-3">
        <div class="form-section-title">Bank & ID Details</div>
        <div class="row g-2">
          <div class="col-12">
            <label class="form-label">Aadhaar Number</label>
            <input type="text" name="aadhaar_no" class="form-control" value="<%= member.aadhaar_no || '' %>" maxlength="12">
          </div>
          <div class="col-12">
            <label class="form-label">Bank Name</label>
            <input type="text" name="bank_name" class="form-control" value="<%= member.bank_name || '' %>">
          </div>
          <div class="col-md-7">
            <label class="form-label">Bank Account Number</label>
            <input type="text" name="bank_account_no" class="form-control" value="<%= member.bank_account_no || '' %>">
          </div>
          <div class="col-md-5">
            <label class="form-label">IFSC Code</label>
            <input type="text" name="ifsc_code" class="form-control" value="<%= member.ifsc_code || '' %>" style="text-transform:uppercase;">
          </div>
        </div>
      </div>

      <div class="form-card">
        <div class="form-section-title">Profile Picture</div>
        <% if (member.profile_picture) { %>
          <img src="<%= member.profile_picture %>" alt="Profile" style="width:80px;height:80px;object-fit:cover;border-radius:8px;" class="mb-2">
        <% } %>
        <input type="file" name="profile_picture" class="form-control" accept="image/*">
        <small class="text-muted">Max 2MB. JPG, PNG, WebP.</small>
      </div>
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>
      <%= typeof isEdit !== 'undefined' && isEdit ? 'Update Member' : 'Create' %>
    </button>
    <% if (typeof isEdit === 'undefined' || !isEdit) { %>
    <button type="submit" name="_action" value="create_close" class="btn btn-secondary">Create and close</button>
    <% } %>
    <a href="/members" class="btn btn-link text-muted">or Cancel</a>
  </div>
</form>

