<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>

<div class="wrapper d-flex">
  <!-- Sidebar -->
  <nav id="sidebar" class="sidebar d-flex flex-column">
    <div class="sidebar-header p-3 text-center border-bottom">
      <img src="/images/logo.png" alt="SICTADAU" class="sidebar-logo mb-2" onerror="this.style.display='none'">
      <div class="sidebar-brand">
        <div class="brand-title">SICTADAU</div>
        <div class="brand-sub text-muted small">Union Management</div>
      </div>
    </div>

    <ul class="nav flex-column px-2 py-3 flex-grow-1">
      <li class="nav-item">
        <a href="/dashboard" class="nav-link <%= locals.title && locals.title.includes('Dashboard') ? 'active' : '' %>">
          <i class="bi bi-speedometer2 me-2"></i> Dashboard
        </a>
      </li>
      <li class="nav-item">
        <a href="/projects" class="nav-link <%= locals.title && (locals.title.includes('Working Report') || locals.title.includes('Invoice')) ? 'active' : '' %>">
          <i class="bi bi-file-earmark-text me-2"></i> Working Reports
        </a>
      </li>
      <li class="nav-item">
        <a href="/vouchers" class="nav-link <%= locals.title && locals.title.includes('Voucher') ? 'active' : '' %>">
          <i class="bi bi-receipt me-2"></i> Artist Vouchers
        </a>
      </li>
      <li class="nav-item">
        <a href="/members" class="nav-link <%= locals.title && (locals.title.includes('Member') || locals.title.includes('Artist')) ? 'active' : '' %>">
          <i class="bi bi-people me-2"></i> Members
        </a>
      </li>
      <li class="nav-item">
        <a href="/statements" class="nav-link <%= locals.title && locals.title.includes('Statement') ? 'active' : '' %>">
          <i class="bi bi-journal-text me-2"></i> Statement
        </a>
      </li>

      <% if (currentUser && ['admin','superadmin'].includes(currentUser.role)) { %>
      <li class="nav-item mt-3">
        <span class="nav-section-title px-3 text-muted small text-uppercase">Administration</span>
      </li>
      <li class="nav-item">
        <a href="/users" class="nav-link <%= locals.title && locals.title.includes('User') ? 'active' : '' %>">
          <i class="bi bi-person-gear me-2"></i> Users
        </a>
      </li>
      <li class="nav-item">
        <a href="/projects/representatives" class="nav-link">
          <i class="bi bi-person-badge me-2"></i> Representatives
        </a>
      </li>
      <% } %>
    </ul>

    <div class="sidebar-footer border-top p-3">
      <div class="d-flex align-items-center gap-2 mb-2">
        <div class="user-avatar"><i class="bi bi-person-circle fs-5"></i></div>
        <div class="flex-grow-1 overflow-hidden">
          <div class="small fw-semibold text-truncate"><%= currentUser ? currentUser.name : '' %></div>
          <div class="x-small text-muted text-truncate"><%= currentUser ? currentUser.role : '' %></div>
        </div>
      </div>
      <div class="d-flex gap-2">
        <a href="/users/change-password" class="btn btn-sm btn-outline-secondary flex-fill">
          <i class="bi bi-key"></i>
        </a>
        <form action="/auth/logout" method="POST" class="flex-fill">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn btn-sm btn-outline-danger w-100">
            <i class="bi bi-box-arrow-right"></i> Logout
          </button>
        </form>
      </div>
    </div>
  </nav>

  <!-- Main content -->
  <div class="main-content flex-grow-1 d-flex flex-column">
    <!-- Top bar -->
    <header class="topbar d-flex align-items-center px-4 border-bottom">
      <button id="sidebarToggle" class="btn btn-sm btn-outline-secondary me-3 d-md-none">
        <i class="bi bi-list"></i>
      </button>
      <nav aria-label="breadcrumb" class="flex-grow-1">
        <ol class="breadcrumb mb-0">
          <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
          <li class="breadcrumb-item active"><%= title %></li>
        </ol>
      </nav>
      <div class="ms-auto text-muted small d-none d-md-block">
        <i class="bi bi-calendar3 me-1"></i>
        <%= new Date().toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %>
      </div>
    </header>

    <!-- Flash messages -->
    <div class="container-fluid px-4 pt-3">
      <% if (flash_success && flash_success.length) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <i class="bi bi-check-circle me-2"></i><%= flash_success[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (flash_error && flash_error.length) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <i class="bi bi-exclamation-circle me-2"></i><%= flash_error[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (flash_info && flash_info.length) { %>
        <div class="alert alert-info alert-dismissible fade show" role="alert">
          <i class="bi bi-info-circle me-2"></i><%= flash_info[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
    </div>

    <!-- Page content -->
    <main class="container-fluid px-4 py-3 flex-grow-1">
      <%- body %>
    </main>

    <footer class="text-center text-muted small py-2 border-top">
      SICTADAU &copy; <%= new Date().getFullYear() %> — South Indian Cine, Television Artistes and Dubbing Artistes Union
    </footer>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap5.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
<script src="/js/app.js"></script>
</body>
</html>
