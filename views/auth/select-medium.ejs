<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Select Medium — SICTADAU</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin: 0; padding: 20px;
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      background: linear-gradient(135deg, #1a1d5e 0%, #303493 60%, #4a4fb5 100%);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    .wrap { max-width: 580px; width: 100%; }

    .logo-row { display: flex; align-items: center; gap: 14px; margin-bottom: 36px; }
    .logo-row img { width: 56px; height: 56px; object-fit: contain; border-radius: 10px; background: rgba(255,255,255,.15); padding: 6px; }
    .brand { color: #fff; }
    .brand-name { font-size: 18px; font-weight: 800; letter-spacing: -.3px; }
    .brand-sub  { font-size: 11px; color: rgba(255,255,255,.6); }

    .greeting { color: rgba(255,255,255,.65); font-size: 13px; margin-bottom: 6px; }
    .heading   { color: #fff; font-size: 26px; font-weight: 800; margin: 0 0 32px; letter-spacing: -.4px; }

    .cards { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 480px) { .cards { grid-template-columns: 1fr; } }

    .card-btn {
      background: rgba(255,255,255,.1);
      border: 2px solid rgba(255,255,255,.22);
      border-radius: 14px;
      padding: 34px 24px;
      text-align: center;
      cursor: pointer;
      width: 100%;
      color: #fff;
      transition: background .18s, border-color .18s, transform .18s;
    }
    .card-btn:hover {
      background: rgba(255,255,255,.2);
      border-color: rgba(255,255,255,.6);
      transform: translateY(-3px);
    }
    .card-btn .icon { font-size: 52px; display: block; margin-bottom: 14px; }
    .card-btn .label { font-size: 20px; font-weight: 700; margin-bottom: 6px; }
    .card-btn .sub   { font-size: 12px; color: rgba(255,255,255,.65); line-height: 1.5; }

    .footer { text-align: center; margin-top: 28px; font-size: 11px; color: rgba(255,255,255,.4); }
    .footer a { color: rgba(255,255,255,.55); text-decoration: none; }
    .footer a:hover { color: rgba(255,255,255,.8); }
  </style>
</head>
<body>
<div class="wrap">

  <div class="logo-row">
    <img src="/images/logo.png" alt="SICTADAU" onerror="this.style.display='none'">
    <div class="brand">
      <div class="brand-name">SICTADAU</div>
      <div class="brand-sub">Union Management System</div>
    </div>
  </div>

  <p class="greeting"><i class="bi bi-hand-wave me-1"></i>Welcome back, <strong><%= currentUser ? currentUser.name : 'User' %></strong></p>
  <h1 class="heading">Select your working medium</h1>

  <div class="cards">

    <form action="/auth/select-medium" method="POST">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <input type="hidden" name="medium" value="Film">
      <button type="submit" class="card-btn">
        <span class="icon">🎬</span>
        <div class="label">Film / Movie</div>
        <div class="sub">Feature films &amp; dubbed content<br>with GW Fund &amp; rep deductions</div>
      </button>
    </form>

    <form action="/auth/select-medium" method="POST">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <input type="hidden" name="medium" value="Television">
      <button type="submit" class="card-btn">
        <span class="icon">📺</span>
        <div class="label">Television</div>
        <div class="sub">Episode-based TV projects<br>full payment to artists</div>
      </button>
    </form>

  </div>

  <div class="footer">
    <form action="/auth/logout" method="POST" class="d-inline">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <button type="submit" style="background:none;border:none;padding:0;cursor:pointer;color:rgba(255,255,255,.4);font-size:11px;font-family:inherit;">
        <i class="bi bi-box-arrow-right me-1"></i>Logout
      </button>
    </form>
    &nbsp;&bull;&nbsp; SICTADAU &copy; <%= new Date().getFullYear() %>
  </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
