<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'SICTADAU' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css">
  <link rel="stylesheet" href="/css/app.css">
  <%- typeof pageStyles !== 'undefined' ? pageStyles : '' %>
</head>
<body data-medium="<%= typeof activeMedium !== 'undefined' ? activeMedium : 'Film' %>">
<div class="wrapper d-flex">

  <!-- ══ Sidebar ══════════════════════════════════════ -->
  <nav id="sidebar" class="sidebar">

    <!-- Brand -->
    <div class="sidebar-header">
      <img src="/images/logo.png" alt="SICTADAU" class="sidebar-logo" onerror="this.style.display='none'">
      <div>
        <div class="brand-title">SICTADAU</div>
        <span class="brand-sub">Union Management</span>
      </div>
    </div>

    <!-- Medium switcher -->
    <% if (currentUser && activeMedium) { %>
    <div class="medium-switcher">
      <div class="medium-switcher-label">Active Medium</div>
      <div class="medium-switcher-track">
        <form action="/auth/select-medium" method="POST" style="flex:1;display:contents;">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <input type="hidden" name="medium" value="Film">
          <button type="submit" class="medium-pill <%= activeMedium === 'Film' ? 'medium-pill-active' : '' %>">
            <i class="bi bi-camera-reels-fill"></i> Film
          </button>
        </form>
        <form action="/auth/select-medium" method="POST" style="flex:1;display:contents;">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <input type="hidden" name="medium" value="Television">
          <button type="submit" class="medium-pill <%= activeMedium === 'Television' ? 'medium-pill-active' : '' %>">
            <i class="bi bi-tv-fill"></i> TV
          </button>
        </form>
      </div>
    </div>
    <% } %>

    <!-- Nav -->
    <ul class="nav flex-column flex-grow-1">
      <li class="nav-item">
        <a href="/dashboard" class="nav-link <%= locals.activePage === 'dashboard' ? 'active' : '' %>">
          <i class="bi bi-speedometer2"></i>Dashboard
        </a>
      </li>
      <li class="nav-item">
        <a href="/projects" class="nav-link <%= locals.activePage === 'projects' ? 'active' : '' %>">
          <i class="bi bi-file-earmark-text"></i><%= activeMedium === 'Television' ? 'TV Projects' : 'Working Reports' %>
        </a>
      </li>
      <li class="nav-item">
        <a href="/vouchers" class="nav-link <%= locals.activePage === 'vouchers' ? 'active' : '' %>">
          <i class="bi bi-receipt"></i>Artist Vouchers
        </a>
      </li>
      <li class="nav-item">
        <a href="/members" class="nav-link <%= locals.activePage === 'members' ? 'active' : '' %>">
          <i class="bi bi-people"></i>Members
        </a>
      </li>
      <li class="nav-item">
        <a href="/statements" class="nav-link <%= locals.activePage === 'statements' ? 'active' : '' %>">
          <i class="bi bi-journal-text"></i>Statement
        </a>
      </li>
      <!-- Reports nav hidden -->

      <% if (currentUser && ['admin','superadmin'].includes(currentUser.role)) { %>
      <span class="nav-section-label">Administration</span>
      <li class="nav-item">
        <a href="/users" class="nav-link <%= locals.activePage === 'users' ? 'active' : '' %>">
          <i class="bi bi-person-gear"></i>Users
        </a>
      </li>
      <li class="nav-item">
        <a href="/projects/representatives" class="nav-link <%= locals.activePage === 'reps' ? 'active' : '' %>">
          <i class="bi bi-person-badge"></i>Representatives
        </a>
      </li>
      <!-- Rep Income nav hidden -->
      <% } %>
    </ul>

    <!-- Footer / user info -->
    <div class="sidebar-footer">
      <% if (currentUser) { %>
      <div class="user-card">
        <div class="user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></div>
        <div class="overflow-hidden">
          <div class="user-name"><%= currentUser.name %></div>
          <div class="user-role"><%= currentUser.role %></div>
        </div>
      </div>
      <div class="d-flex gap-2">
        <a href="/users/change-password" class="btn btn-sm btn-outline-secondary flex-fill" title="Change Password">
          <i class="bi bi-key me-1"></i>Password
        </a>
        <form action="/auth/logout" method="POST" class="flex-fill">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn btn-sm btn-outline-danger w-100">
            <i class="bi bi-box-arrow-right me-1"></i>Logout
          </button>
        </form>
      </div>
      <% } %>
    </div>
  </nav>
  <!-- ══ End Sidebar ══════════════════════════════════ -->

  <!-- ══ Main ═════════════════════════════════════════ -->
  <div class="main-content">

    <!-- Topbar -->
    <header class="topbar">
      <button id="sidebarToggle" class="btn btn-sm btn-outline-secondary d-md-none me-2">
        <i class="bi bi-list fs-5"></i>
      </button>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
          <li class="breadcrumb-item"><a href="/dashboard"><i class="bi bi-house-door me-1"></i>Home</a></li>
          <li class="breadcrumb-item active"><%= typeof title !== 'undefined' ? title.split(' — ')[0] : '' %></li>
        </ol>
      </nav>
      <span class="topbar-date d-none d-md-block">
        <i class="bi bi-calendar3 me-1 text-primary"></i>
        <%= new Date().toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric', weekday:'short' }) %>
      </span>
    </header>

    <!-- Flash messages -->
    <div class="container-fluid px-4 pt-3">
      <% if (flash_success && flash_success.length) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <i class="bi bi-check-circle-fill"></i>
          <span><%= flash_success[0] %></span>
          <button type="button" class="btn-close btn-sm ms-auto" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (flash_error && flash_error.length) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <i class="bi bi-exclamation-circle-fill"></i>
          <span><%= flash_error[0] %></span>
          <button type="button" class="btn-close btn-sm ms-auto" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
    </div>

    <!-- Page body -->
    <main class="container-fluid px-4 py-3 flex-grow-1">
      <%- body %>
    </main>

    <footer>
      SICTADAU &copy; <%= new Date().getFullYear() %> &mdash; ESTD 1983 &bull; Regd No. 1337/MDS &bull; Affiliated with FEFSI
    </footer>
  </div>
  <!-- ══ End Main ══════════════════════════════════════ -->
</div>

<!-- Mobile overlay -->
<div id="sidebarOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1049;" onclick="closeSidebar()"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap5.min.js"></script>
<script src="/js/app.js"></script>
<%- typeof pageScripts !== 'undefined' ? pageScripts : '' %>
<%- typeof script !== 'undefined' ? script : '' %>
</body>
</html>
