<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'SICTADAU' %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
<div class="wrapper d-flex">

  <!-- Sidebar -->
  <nav id="sidebar" class="sidebar d-flex flex-column">
    <div class="sidebar-header p-3 text-center border-bottom">
      <img src="/images/logo.png" alt="SICTADAU" class="sidebar-logo mb-2" onerror="this.style.display='none'">
      <div class="brand-title">SICTADAU</div>
      <div class="text-muted" style="font-size:0.68rem;">Union Management</div>
    </div>

    <ul class="nav flex-column px-2 py-3 flex-grow-1">
      <li class="nav-item">
        <a href="/dashboard" class="nav-link <%= locals.activePage === 'dashboard' ? 'active' : '' %>">
          <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </a>
      </li>
      <li class="nav-item">
        <a href="/projects" class="nav-link <%= locals.activePage === 'projects' ? 'active' : '' %>">
          <i class="bi bi-file-earmark-text me-2"></i>Working Reports
        </a>
      </li>
      <li class="nav-item">
        <a href="/vouchers" class="nav-link <%= locals.activePage === 'vouchers' ? 'active' : '' %>">
          <i class="bi bi-receipt me-2"></i>Artist Vouchers
        </a>
      </li>
      <li class="nav-item">
        <a href="/members" class="nav-link <%= locals.activePage === 'members' ? 'active' : '' %>">
          <i class="bi bi-people me-2"></i>Members
        </a>
      </li>
      <li class="nav-item">
        <a href="/statements" class="nav-link <%= locals.activePage === 'statements' ? 'active' : '' %>">
          <i class="bi bi-journal-text me-2"></i>Statement
        </a>
      </li>
      <% if (currentUser && ['admin','superadmin'].includes(currentUser.role)) { %>
      <li class="nav-item mt-3">
        <span class="px-3 text-muted" style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.08em;">Administration</span>
      </li>
      <li class="nav-item">
        <a href="/users" class="nav-link <%= locals.activePage === 'users' ? 'active' : '' %>">
          <i class="bi bi-person-gear me-2"></i>Users
        </a>
      </li>
      <li class="nav-item">
        <a href="/projects/representatives" class="nav-link <%= locals.activePage === 'reps' ? 'active' : '' %>">
          <i class="bi bi-person-badge me-2"></i>Representatives
        </a>
      </li>
      <% } %>
    </ul>

    <div class="sidebar-footer border-top p-3">
      <% if (currentUser) { %>
      <div class="d-flex align-items-center gap-2 mb-2">
        <i class="bi bi-person-circle fs-4 text-muted"></i>
        <div class="overflow-hidden">
          <div class="small fw-semibold text-white text-truncate" style="max-width:140px;"><%= currentUser.name %></div>
          <div class="text-muted" style="font-size:0.7rem;text-transform:capitalize;"><%= currentUser.role %></div>
        </div>
      </div>
      <div class="d-flex gap-2">
        <a href="/users/change-password" class="btn btn-sm btn-outline-secondary" title="Change Password">
          <i class="bi bi-key"></i>
        </a>
        <form action="/auth/logout" method="POST" class="flex-fill">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn btn-sm btn-outline-danger w-100">
            <i class="bi bi-box-arrow-right me-1"></i>Logout
          </button>
        </form>
      </div>
      <% } %>
    </div>
  </nav>

  <!-- Main content -->
  <div class="main-content flex-grow-1 d-flex flex-column">
    <header class="topbar d-flex align-items-center px-4 border-bottom">
      <button id="sidebarToggle" class="btn btn-sm btn-outline-secondary me-3 d-md-none">
        <i class="bi bi-list"></i>
      </button>
      <nav aria-label="breadcrumb" class="flex-grow-1">
        <ol class="breadcrumb mb-0 small">
          <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
          <li class="breadcrumb-item active"><%= typeof title !== 'undefined' ? title.split(' — ')[0] : '' %></li>
        </ol>
      </nav>
      <div class="ms-auto text-muted small d-none d-md-block">
        <i class="bi bi-calendar3 me-1"></i>
        <%= new Date().toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %>
      </div>
    </header>

    <div class="container-fluid px-4 pt-3">
      <% if (flash_success && flash_success.length) { %>
        <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
          <i class="bi bi-check-circle me-2"></i><%= flash_success[0] %>
          <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (flash_error && flash_error.length) { %>
        <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
          <i class="bi bi-exclamation-circle me-2"></i><%= flash_error[0] %>
          <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
    </div>

    <main class="container-fluid px-4 py-3 flex-grow-1">
      <%- body %>
    </main>

    <footer class="text-center text-muted py-2 border-top" style="font-size:0.72rem;">
      SICTADAU &copy; <%= new Date().getFullYear() %> — ESTD 1983 &bull; Regd No. 1337/MDS &bull; Affiliated with FEFSI
    </footer>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap5.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
<script src="/js/app.js"></script>
</body>
</html>
