<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Invoice — <%= project.film_name %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <style>
    body { font-family: 'Times New Roman', serif; font-size: 13px; }
    .invoice-container { max-width: 900px; margin: 0 auto; padding: 20px; }
    .header-table { width: 100%; margin-bottom: 15px; }
    .union-logo { width: 80px; height: 80px; object-fit: contain; }
    .section-header { background: #f0f0f0; font-weight: bold; padding: 4px 8px; border: 1px solid #ccc; }
    table.data-table { width: 100%; border-collapse: collapse; }
    table.data-table th, table.data-table td { border: 1px solid #999; padding: 5px 8px; }
    table.data-table th { background: #f8f8f8; font-weight: bold; }
    .meta-row { font-size: 12px; }
    .total-box { border: 1px solid #ccc; padding: 8px; }
    .signature-row { margin-top: 40px; }
    @media print { .no-print { display:none !important; } body { margin: 0; } }
  </style>
</head>
<body>
<div class="invoice-container">
  <!-- Print button -->
  <div class="no-print mb-3 d-flex gap-2">
    <button onclick="window.print()" class="btn btn-sm btn-dark"><i class="bi bi-printer me-1"></i>Print</button>
    <a href="/projects/<%= project.id %>" class="btn btn-sm btn-outline-secondary">Back</a>
  </div>

  <!-- Header meta -->
  <div class="d-flex justify-content-between mb-2 meta-row">
    <div>
      <div>Project Entry Date : <strong><%= project.start_date ? new Date(project.start_date).toLocaleDateString('en-IN', {year:'numeric', month:'2-digit', day:'2-digit'}) : '—' %></strong></div>
      <div>Project End Date : <strong><%= project.end_date ? new Date(project.end_date).toLocaleDateString('en-IN', {year:'numeric', month:'2-digit', day:'2-digit'}) : '—' %></strong></div>
    </div>
    <div class="text-end">
      <div>Invoice No. : <strong><%= project.invoice_no || '—' %></strong></div>
      <div>Status : <strong><%= project.status %></strong></div>
    </div>
  </div>

  <!-- From / To -->
  <table class="header-table mb-3" style="border:1px solid #ccc;">
    <tr>
      <td style="width:50%;padding:12px;border-right:1px solid #ccc;vertical-align:top;">
        <img src="/images/logo.png" alt="Logo" class="union-logo" style="float:left;margin-right:10px;" onerror="this.style.display='none'">
        <div><strong>From:</strong></div>
        <div><strong>South Indian Cine, Television Artistes and Dubbing Artistes Union</strong></div>
        <div>ESTD : <strong>1983</strong> - Regd No. <strong>1337/MDS</strong></div>
        <div>Affiliated with <strong>FEFSI</strong></div>
        <div>10, Vijayaraghavapuram 4th Street, Saligramam, Chennai-600093</div>
        <div>044-23650223, 23650225, 23650229</div>
        <div>sictadau@gmail.com</div>
      </td>
      <td style="width:50%;padding:12px;vertical-align:top;">
        <div><strong>To:</strong></div>
        <div><strong><%= project.production_company %></strong></div>
        <div>Project Name : <strong><%= project.film_name %></strong></div>
        <div>Project Language : <strong><%= project.language || '—' %></strong></div>
        <% if (project.place_of_dubbing) { %><div>POD : <strong><%= project.place_of_dubbing %></strong></div><% } %>
        <% if (project.production_company_address) { %><div><%= project.production_company_address %></div><% } %>
        <% if (project.production_contact_no) { %><div>Phone: <%= project.production_contact_no %></div><% } %>
        <% if (project.company_email) { %><div>Email: <%= project.company_email %></div><% } %>
        <% if (project.rep_name) { %><div>Representative: <strong><%= project.rep_name %></strong></div><% } %>
      </td>
    </tr>
  </table>

  <!-- Voucher table -->
  <table class="data-table mb-3">
    <thead>
      <tr>
        <th>ID</th>
        <th>Mem No.</th>
        <th>Dubbing Artist Name</th>
        <th>Character</th>
        <th class="text-end">Total</th>
      </tr>
    </thead>
    <tbody>
      <% vouchers.forEach(v => { %>
      <tr>
        <td><%= v.id %></td>
        <td><%= v.membership_no %></td>
        <td><%= v.full_name %></td>
        <td><%= v.character || '—' %></td>
        <td class="text-end">Rs. <%= (v.amount||0).toLocaleString('en-IN') %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <!-- Bank + Totals -->
  <div class="row">
    <div class="col-6">
      <div style="font-size:12px;line-height:1.8;">
        <div>A/C Name : <strong>South Indian Cine, Television Artistes and Dubbing Artistes Union</strong></div>
        <div>A/C NO. : <strong>1616135000004793</strong></div>
        <div>IFSC CODE : <strong>KVBL0001616</strong></div>
        <div>BANK : <strong>KARUR VYSYA BANK, K.K.Nagar Branch</strong></div>
        <div>PAN NO. : <strong>AADAS9061M</strong></div>
      </div>
    </div>
    <div class="col-6">
      <table class="total-box" style="width:100%;font-size:13px;">
        <tr>
          <td>Total</td>
          <td class="text-end"><strong>Rs. <%= vouchers.reduce((s,v)=>s+(v.amount||0),0).toLocaleString('en-IN') %></strong></td>
        </tr>
        <tr>
          <td>Total Amount Received</td>
          <td class="text-end"><strong>Rs. <%= totalPaid.toLocaleString('en-IN') %></strong></td>
        </tr>
        <tr>
          <td>Balance Amount</td>
          <td class="text-end"><strong>Rs. <%= ((project.amount||0) - totalPaid).toLocaleString('en-IN') %></strong></td>
        </tr>
      </table>
    </div>
  </div>

  <!-- Payment history -->
  <% if (payments.length > 0) { %>
  <div class="mt-3" style="border:1px solid #ccc;padding:10px;">
    <div class="fw-bold mb-2">Payments History</div>
    <table class="data-table">
      <thead><tr><th>ID</th><th>Transaction Date</th><th>Payment Type</th><th>Notes</th><th class="text-end">Amount</th></tr></thead>
      <tbody>
        <% payments.forEach(p => { %>
        <tr>
          <td><%= p.id %></td>
          <td><%= p.transaction_date %></td>
          <td><%= p.payment_type %></td>
          <td><%= p.notes || '' %></td>
          <td class="text-end">Rs. <%= p.amount.toLocaleString('en-IN') %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>

  <!-- Signatures -->
  <div class="signature-row d-flex justify-content-between mt-5">
    <div>Co-ordinator <%= project.rep_name ? 'Mr.' + project.rep_name : '' %></div>
    <div class="text-center">Manager / Secretary / Treasurer</div>
    <div>For <%= project.production_company %></div>
  </div>
  <div class="mt-3" style="font-size:11px;color:#666;">*Cheque subject to realisation</div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</body>
</html>
