<% activePage = 'reps'; %>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <h4 class="fw-bold mb-0">Representatives</h4>
  <div class="d-flex gap-2">
    <a href="/rep-payments" class="btn btn-sm btn-primary">
      <i class="bi bi-cash-stack me-1"></i>View Rep Income
    </a>
    <a href="/projects" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-4">
    <div class="form-card">
      <div class="form-section-title">Add Representative</div>
      <form action="/projects/representatives" method="POST">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div class="mb-2">
          <label class="form-label">Name <span class="text-danger">*</span></label>
          <input type="text" name="name" class="form-control" required>
        </div>
        <div class="mb-2">
          <label class="form-label">Contact</label>
          <input type="text" name="contact" class="form-control">
        </div>
        <div class="mb-3">
          <label class="form-label">Email</label>
          <input type="email" name="email" class="form-control">
        </div>
        <button type="submit" class="btn btn-primary w-100">Add Representative</button>
      </form>
    </div>
  </div>

  <div class="col-md-8">
    <div class="table-card card">
      <div class="card-header fw-semibold py-2">All Representatives</div>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead><tr><th>#</th><th>Name</th><th>Contact</th><th>Email</th><th>Status</th><th></th></tr></thead>
          <tbody>
            <% reps.forEach(r => { %>
            <tr>
              <td class="text-muted small"><%= r.id %></td>
              <td class="fw-medium"><%= r.name %></td>
              <td class="small"><%= r.contact || '—' %></td>
              <td class="small"><%= r.email || '—' %></td>
              <td><span class="badge <%= r.is_active ? 'badge-active' : 'badge-cancelled' %>"><%= r.is_active ? 'Active' : 'Inactive' %></span></td>
              <td>
                <% if (r.is_active) { %>
                <form action="/projects/representatives/<%= r.id %>" method="POST" class="d-inline">
                  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <input type="hidden" name="_method" value="DELETE">
                  <button type="submit" class="btn btn-xs btn-outline-danger" style="font-size:0.75rem;padding:2px 8px;" data-confirm="Deactivate this representative?">Remove</button>
                </form>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
