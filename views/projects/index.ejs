<% activePage = 'projects'; %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0">Working Reports</h4>
    <small class="text-muted"><%= stats.total %> projects &bull; ₹<%= Math.round(stats.total_amount||0).toLocaleString('en-IN') %> billed &bull; ₹<%= Math.round(stats.total_received||0).toLocaleString('en-IN') %> received</small>
  </div>
  <a href="/projects/create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Project</a>
</div>

<div class="card mb-3 border-0 shadow-sm">
  <div class="card-body py-2">
    <form class="row g-2 align-items-end" method="GET">
      <div class="col-md-5">
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Search film, company, invoice..." value="<%= search %>">
      </div>
      <div class="col-md-3">
        <select name="status" class="form-select form-select-sm">
          <option value="">All Status</option>
          <% STATUSES.forEach(s => { %><option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s %></option><% }) %>
        </select>
      </div>
      <div class="col-auto">
        <button class="btn btn-sm btn-primary">Filter</button>
        <a href="/projects" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
      </div>
    </form>
    <small class="text-muted d-block mt-2"><i class="bi bi-info-circle"></i> Click column headers to sort • Default: Latest first</small>
  </div>
</div>

<div class="table-card card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table id="projectsTable" class="table table-hover mb-0">
        <thead>
          <tr>
            <th>Date</th>
            <th>End Date</th>
            <th>Production Company</th>
            <th>Project Name</th>
            <th>Representative</th>
            <th>Amount</th>
            <th>Status</th>
            <th style="width: 80px;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% projects.forEach(p => { %>
          <tr>
            <td class="small text-muted"><%= p.start_date ? new Date(p.start_date).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : '—' %></td>
            <td class="small text-muted"><%= p.end_date ? new Date(p.end_date).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : '—' %></td>
            <td class="small"><%= p.production_company %></td>
            <td><a href="/projects/<%= p.id %>" class="fw-medium text-decoration-none"><%= p.film_name %><% if(p.language) { %> <span class="text-muted small">(<%= p.language %>)</span><% } %></a></td>
            <td class="small"><%= p.rep_name || '—' %></td>
            <td class="small fw-medium"><%= p.amount > 0 ? p.amount.toLocaleString('en-IN') : '0' %></td>
            <td>
              <% if (p.status === 'Paid') { %><span class="badge badge-paid">Paid</span>
              <% } else if (p.status === 'Completed') { %><span class="badge badge-completed">Completed</span>
              <% } else { %><span class="badge badge-pending">Pending</span>
              <% } %>
            </td>
            <td class="text-center">
              <div class="btn-group btn-group-sm" role="group">
                <a href="/projects/<%= p.id %>" class="btn btn-outline-secondary" title="View"><i class="bi bi-eye"></i></a>
                <a href="/projects/<%= p.id %>/edit" class="btn btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
$(function(){
  initDataTable('#projectsTable', {
    order: [[0, 'desc']], // Latest projects first
    pageLength: 100,
    pagingType: 'simple', // Prev/Next buttons only
    columnDefs: [
      { orderable: false, targets: [7] },
      { responsivePriority: 1, targets: [3, 6] },
      { responsivePriority: 2, targets: [4] }
    ]
  });
});
</script>
