<% activePage = 'projects'; %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0">Working Reports</h4>
    <small class="text-muted"><%= stats.total %> projects &bull; ₹<%= Math.round(stats.total_amount||0).toLocaleString('en-IN') %> billed &bull; ₹<%= Math.round(stats.total_received||0).toLocaleString('en-IN') %> received</small>
  </div>
  <a href="/projects/create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Project</a>
</div>

<div class="card mb-3 border-0 shadow-sm">
  <div class="card-body py-2">
    <form class="row g-2 align-items-end" method="GET">
      <div class="col-md-5">
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Search film, company, invoice..." value="<%= search %>">
      </div>
      <div class="col-md-3">
        <select name="status" class="form-select form-select-sm">
          <option value="">All Status</option>
          <% STATUSES.forEach(s => { %><option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s %></option><% }) %>
        </select>
      </div>
      <div class="col-auto">
        <button class="btn btn-sm btn-primary">Filter</button>
        <a href="/projects" class="btn btn-sm btn-outline-secondary ms-1">Clear</a>
      </div>
    </form>
    <small class="text-muted d-block mt-2"><i class="bi bi-info-circle"></i> Click column headers to sort &bull; Default: Latest first</small>
  </div>
</div>

<div class="table-card card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table id="projectsTable" class="table table-hover mb-0">
        <thead>
          <tr>
            <th>Date</th>
            <th>End Date</th>
            <th>Production Company</th>
            <th>Project Name</th>
            <th>Representative</th>
            <th>Amount</th>
            <th>Status</th>
            <th style="width: 80px;">Actions</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </div>
</div>

<script>
(function(){
  const SEARCH = <%- JSON.stringify(search) %>;
  const STATUS = <%- JSON.stringify(status) %>;

  function escHtml(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  // Parse YYYY-MM-DD prefix directly — avoids UTC-midnight timezone shift in IST browsers
  function fmtDate(d) {
    if (!d) return '—';
    var m = String(d).match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (!m) return String(d);
    var mon = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return m[3] + '-' + mon[parseInt(m[2])-1] + '-' + m[1];
  }
  function fmtAmount(n) {
    return n > 0 ? Number(n).toLocaleString('en-IN') : '0';
  }

  $('#projectsTable').DataTable({
    serverSide: true,
    processing: true,
    searching: false,
    ajax: {
      url: '/projects/data',
      data: function(d) {
        d.search.value = SEARCH;
        d.status = STATUS;
      }
    },
    columns: [
      { data: 'start_date', className: 'small text-muted', render: function(d) { return fmtDate(d); } },
      { data: 'end_date', className: 'small text-muted', render: function(d) { return fmtDate(d); } },
      { data: 'production_company', className: 'small', render: function(d) { return escHtml(d||'—'); } },
      {
        data: null, render: function(row) {
          var lang = row.language ? ' <span class="text-muted small">(' + escHtml(row.language) + ')</span>' : '';
          return '<a href="/projects/' + row.id + '" class="fw-medium text-decoration-none">' + escHtml(row.film_name) + lang + '</a>';
        }
      },
      { data: 'rep_name', className: 'small', render: function(d) { return d ? escHtml(d) : '—'; } },
      { data: 'amount', className: 'small fw-medium', render: function(d) { return fmtAmount(d); } },
      {
        data: 'status',
        render: function(d) {
          if (d === 'Paid') return '<span class="badge badge-paid">Paid</span>';
          if (d === 'Completed') return '<span class="badge badge-completed">Completed</span>';
          return '<span class="badge badge-pending">Pending</span>';
        }
      },
      {
        data: null, orderable: false, className: 'text-center',
        render: function(row) {
          return '<div class="btn-group btn-group-sm" role="group">' +
            '<a href="/projects/' + row.id + '" class="btn btn-outline-secondary" title="View"><i class="bi bi-eye"></i></a>' +
            '<a href="/projects/' + row.id + '/edit" class="btn btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>' +
            '</div>';
        }
      }
    ],
    order: [[0, 'desc']],
    pageLength: 25,
    lengthMenu: [[25, 50, 100], ['25', '50', '100']],
    pagingType: 'simple_numbers',
    dom: "<'row mb-2'<'col-sm-12 col-md-6'B><'col-sm-6 col-md-6'l>>" +
         "<'row'<'col-sm-12'tr>>" +
         "<'row mt-2 align-items-center'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7 d-flex justify-content-end'p>>",
    buttons: [
      {
        text: '<i class="bi bi-file-earmark-csv me-1"></i>Export CSV',
        className: 'btn btn-sm btn-outline-secondary',
        action: function() {
          window.location.href = '/projects/export?' + new URLSearchParams({search: SEARCH, status: STATUS}).toString();
        }
      }
    ],
    language: {
      processing: '<span class="spinner-border spinner-border-sm text-primary me-1" role="status"></span> Loading...',
      lengthMenu: '_MENU_ per page',
      info: 'Showing _START_–_END_ of _TOTAL_',
      infoEmpty: 'No records found',
      infoFiltered: '(filtered)',
      paginate: { first: '«', last: '»', next: '›', previous: '‹' }
    }
  });
})();
</script>
