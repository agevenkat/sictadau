<% activePage = 'reports'; pageScripts = '<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"><\/script>'; %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0">Financial Reports</h4>
    <small class="text-muted">Year-wise income, expense & voucher analysis</small>
  </div>
  <!-- Year selector -->
  <form method="GET" class="d-flex align-items-center gap-2">
    <label class="form-label mb-0 fw-medium">Year:</label>
    <select name="year" class="form-select form-select-sm" style="width:auto;" onchange="this.form.submit()">
      <% years.forEach(function(y){ %>
        <option value="<%= y.y %>" <%= y.y == year ? 'selected' : '' %>><%= y.y %></option>
      <% }) %>
    </select>
  </form>
</div>

<!-- ── KPI row ─────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
  <div class="col-6 col-xl-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fw-bold fs-5 text-success">₹<%= Math.round(yearTotals.total_credit||0).toLocaleString('en-IN') %></div>
      <div class="small text-muted">Total Income <%= year %></div>
    </div>
  </div>
  <div class="col-6 col-xl-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fw-bold fs-5 text-danger">₹<%= Math.round(yearTotals.total_debit||0).toLocaleString('en-IN') %></div>
      <div class="small text-muted">Total Expenses <%= year %></div>
    </div>
  </div>
  <div class="col-6 col-xl-3">
    <%
      const bal = (yearTotals.total_credit||0) - (yearTotals.total_debit||0);
    %>
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fw-bold fs-5 <%= bal >= 0 ? 'text-success' : 'text-danger' %>">
        ₹<%= Math.round(Math.abs(bal)).toLocaleString('en-IN') %> <%= bal >= 0 ? 'Cr' : 'Dr' %>
      </div>
      <div class="small text-muted">Net Balance <%= year %></div>
    </div>
  </div>
  <div class="col-6 col-xl-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fw-bold fs-5 text-primary">₹<%= Math.round(yearVoucherTotals.paid_amount||0).toLocaleString('en-IN') %></div>
      <div class="small text-muted">Vouchers Disbursed <%= year %></div>
    </div>
  </div>
</div>

<!-- ── Charts ──────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">

  <!-- Monthly Income vs Expense -->
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header">
        <span><i class="bi bi-bar-chart-fill text-primary me-2"></i>Monthly Income vs Expense — <%= year %></span>
      </div>
      <div class="card-body" style="position:relative;height:270px;">
        <canvas id="chartMonthly"></canvas>
      </div>
    </div>
  </div>

  <!-- Voucher summary donut -->
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header">
        <span><i class="bi bi-receipt text-primary me-2"></i>Vouchers <%= year %></span>
      </div>
      <div class="card-body d-flex flex-column align-items-center justify-content-center" style="height:270px;">
        <canvas id="chartVoucherStatus" style="max-width:180px;max-height:180px;"></canvas>
        <div class="mt-3 small text-center">
          <div><span style="color:#16a34a;">●</span> Paid: <strong><%= yearVoucherTotals.paid_count||0 %></strong> vouchers — ₹<%= Math.round(yearVoucherTotals.paid_amount||0).toLocaleString('en-IN') %></div>
          <div><span style="color:#f59e0b;">●</span> Pending: <strong><%= yearVoucherTotals.pending_count||0 %></strong> vouchers — ₹<%= Math.round(yearVoucherTotals.pending_amount||0).toLocaleString('en-IN') %></div>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- ── Tables ──────────────────────────────────────────────────────── -->
<div class="row g-3">

  <!-- Income/Expense by Type -->
  <div class="col-lg-5">
    <div class="card">
      <div class="card-header">
        <span><i class="bi bi-tags-fill text-primary me-2"></i>Transactions by Category — <%= year %></span>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead>
            <tr><th>Category</th><th>Type</th><th class="text-end">Count</th><th class="text-end">Total</th></tr>
          </thead>
          <tbody>
            <% if (incomeByType.length === 0) { %>
            <tr><td colspan="4" class="text-center text-muted py-3 small">No data for <%= year %></td></tr>
            <% } else { %>
            <% incomeByType.forEach(function(row) { %>
            <tr>
              <td class="small"><%= row.income_type || '—' %></td>
              <td><span class="badge <%= row.amount_type === 'Credit' ? 'bg-success' : 'bg-danger' %>"><%= row.amount_type %></span></td>
              <td class="small text-end text-muted"><%= row.count %></td>
              <td class="small text-end fw-medium">₹<%= Math.round(row.total||0).toLocaleString('en-IN') %></td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Vouchers by Project -->
  <div class="col-lg-7">
    <div class="card">
      <div class="card-header">
        <span><i class="bi bi-film text-primary me-2"></i>Top Projects by Vouchers — <%= year %></span>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead>
            <tr><th>Project</th><th class="text-end">Vouchers</th><th class="text-end">Paid</th><th class="text-end">Pending</th><th class="text-end">Total</th></tr>
          </thead>
          <tbody>
            <% if (vouchersByProject.length === 0) { %>
            <tr><td colspan="5" class="text-center text-muted py-3 small">No vouchers for <%= year %></td></tr>
            <% } else { %>
            <% vouchersByProject.forEach(function(row) { %>
            <tr>
              <td class="small fw-medium"><%= row.film_name %></td>
              <td class="small text-end text-muted"><%= row.count %></td>
              <td class="small text-end text-success">₹<%= Math.round(row.paid_amount||0).toLocaleString('en-IN') %></td>
              <td class="small text-end text-warning">₹<%= Math.round(row.pending_amount||0).toLocaleString('en-IN') %></td>
              <td class="small text-end fw-medium">₹<%= Math.round(row.total_amount||0).toLocaleString('en-IN') %></td>
            </tr>
            <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>

<script>
(function(){
  const MON_LABELS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  // ── Monthly income vs expense ────────────────────────────────────
  const mfData = <%- JSON.stringify(monthlyFinancials) %>;
  // Build 12-slot arrays
  const credits = new Array(12).fill(0), debits = new Array(12).fill(0);
  mfData.forEach(function(r) {
    const idx = parseInt(r.month, 10) - 1;
    if (idx >= 0 && idx < 12) {
      credits[idx] = Math.round(r.credit || 0);
      debits[idx]  = Math.round(r.debit  || 0);
    }
  });

  new Chart(document.getElementById('chartMonthly'), {
    type: 'bar',
    data: {
      labels: MON_LABELS,
      datasets: [
        { label: 'Income (₹)', data: credits, backgroundColor: 'rgba(22,163,74,0.75)', borderRadius: 4 },
        { label: 'Expense (₹)', data: debits,  backgroundColor: 'rgba(220,38,38,0.65)', borderRadius: 4 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'top', labels: { font: { size: 11 } } } },
      scales: {
        y: {
          ticks: {
            callback: function(v) {
              if (v >= 1e5) return '₹' + (v/1e5).toFixed(1) + 'L';
              if (v >= 1e3) return '₹' + (v/1e3).toFixed(0) + 'K';
              return '₹' + v;
            },
            font: { size: 10 }
          },
          grid: { color: 'rgba(0,0,0,.06)' }
        },
        x: { ticks: { font: { size: 10 } }, grid: { display: false } }
      }
    }
  });

  // ── Voucher status donut ─────────────────────────────────────────
  const paidAmt    = Math.round(<%= yearVoucherTotals.paid_amount    || 0 %>);
  const pendingAmt = Math.round(<%= yearVoucherTotals.pending_amount || 0 %>);
  new Chart(document.getElementById('chartVoucherStatus'), {
    type: 'doughnut',
    data: {
      labels: ['Paid', 'Pending'],
      datasets: [{
        data: [paidAmt, pendingAmt],
        backgroundColor: ['rgba(22,163,74,0.8)', 'rgba(245,158,11,0.8)'],
        borderWidth: 2
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: true,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: function(ctx) { return ' ₹' + ctx.raw.toLocaleString('en-IN'); } } }
      },
      cutout: '60%'
    }
  });
})();
</script>
